<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:Core_Aim.Converters">

    <!-- ═══════════ CONVERTERS ═══════════ -->
    <converters:AppStatusConverter x:Key="StatusConverter" />
    <converters:AppColorConverter x:Key="ColorConverter" />
    <converters:BoolToButtonColorConverter x:Key="BtnColor" />
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- ═══════════ PALETTE — PHANTOM (legacy keys, mapeados ao spec §10) ═══════════ -->
    <!-- Mantemos as chaves antigas (BgApp, TxtPri, etc.) por compatibilidade
         com Pages legados, mas agora apontam EXATAMENTE para os valores do
         documento phantom_docs.txt §10 / PhantomTokens.xaml. -->
    <Color x:Key="CAccent">#FF00F0FF</Color>
    <Color x:Key="CAccentDim">#FF008C99</Color>
    <SolidColorBrush x:Key="Accent"       Color="{StaticResource CAccent}" />
    <SolidColorBrush x:Key="AccentDark"   Color="{StaticResource CAccentDim}" />
    <SolidColorBrush x:Key="AccentDim"    Color="#FF004C55" />
    <!-- Spec: Void #010308 -->
    <SolidColorBrush x:Key="BgApp"        Color="#FF010308" />
    <!-- Spec: Panel #060D1A -->
    <SolidColorBrush x:Key="BgPanel"      Color="#FF060D1A" />
    <!-- Spec: PanelHi (legacy) — usado por Cards -->
    <SolidColorBrush x:Key="BgCard"       Color="#FF0E1726" />
    <!-- Spec: Abyss #03070F (TextBox / inputs) -->
    <SolidColorBrush x:Key="BgInput"      Color="#FF03070F" />
    <SolidColorBrush x:Key="BgHover"      Color="#FF182338" />
    <SolidColorBrush x:Key="BgNav"        Color="#CC03070F" />
    <SolidColorBrush x:Key="ColorGreen"   Color="#FF00FF9D" />
    <SolidColorBrush x:Key="ColorCyan"    Color="#FF80E8FF" />
    <SolidColorBrush x:Key="ColorRed"     Color="#FFFF3000" />
    <SolidColorBrush x:Key="ColorAmber"   Color="#FFFFE000" />
    <!-- Spec: White #D8EEF8 (texto principal) -->
    <SolidColorBrush x:Key="TxtPri"       Color="#FFD8EEF8" />
    <!-- Spec: Text #8AAABB (texto secundário / labels) -->
    <SolidColorBrush x:Key="TxtSec"       Color="#FF8AAABB" />
    <!-- Spec: TextSub #506070 (texto fraco / dim) -->
    <SolidColorBrush x:Key="TxtDim"       Color="#FF506070" />
    <!-- Spec: TextMuted #304050 (placeholders / disabled) -->
    <SolidColorBrush x:Key="TxtMuted"     Color="#FF304050" />
    <SolidColorBrush x:Key="Border1"      Color="#3300F0FF" />
    <SolidColorBrush x:Key="Border2"      Color="#8000F0FF" />

    <!-- ═══════════ WINDOW BUTTONS ═══════════ -->
    <Style x:Key="WinBtn" TargetType="Button">
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#FF506070" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#1A00F0FF" />
                            <Setter Property="Foreground" Value="#FF00F0FF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="WinBtnClose" TargetType="Button" BasedOn="{StaticResource WinBtn}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#33FF3000" />
                            <Setter Property="Foreground" Value="#FFFF3000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ TEXT STYLES (Phantom-aligned) ═══════════ -->
    <Style x:Key="PLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>
    <Style x:Key="PValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>
    <Style x:Key="PValueG" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="{StaticResource ColorGreen}" />
    </Style>
    <Style x:Key="PValueA" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="{StaticResource ColorAmber}" />
    </Style>
    <Style x:Key="PValueB" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="{StaticResource ColorCyan}" />
    </Style>
    <!-- Plasma (Phantom #B400FF) — usado em sliders Velocidade/Suavidade -->
    <Style x:Key="PValueP" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="#FFB400FF" />
    </Style>
    <!-- Orange (entre Solar e Inferno) — usado em sliders de tamanho/crop -->
    <Style x:Key="PValueO" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="#FFFF8800" />
    </Style>
    <!-- SectionTitle: usado no topo da Page. Como o PhantomBalloonHost já tem o título no
         header, mantemos isto pequeno e dim para não duplicar visualmente. -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TxtDim}" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="Visibility" Value="Collapsed" />
    </Style>

    <!-- SubsectionLabel: header pequeno mono dim cyan dentro de cada Card.
         Ex.: "▸ FONTE DE CAPTURA", "▸ MÉTRICAS", "▸ FOV", "▸ YOLO ▸". -->
    <Style x:Key="SubsectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TxtDim}" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>
    <Style x:Key="SubTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TxtDim}" />
        <Setter Property="Margin" Value="0,4,0,10" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <!-- ═══════════ NAV TAB BUTTON — Phantom (electric indicator + glow) ═══════════ -->
    <Style x:Key="NavTab" TargetType="Button">
        <Setter Property="Width" Value="76" />
        <Setter Property="Height" Value="58" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="#FF8AAABB" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="4,3">
                        <Rectangle x:Name="rail" Width="3" HorizontalAlignment="Left"
                                   Fill="#FF00F0FF" Margin="0,6" Opacity="0">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="#FF00F0FF" BlurRadius="14" ShadowDepth="0" Opacity="0.95" />
                            </Rectangle.Effect>
                        </Rectangle>
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1"
                                CornerRadius="0" Margin="6,0,2,0">
                            <Grid>
                                <Rectangle x:Name="topAccent" Height="1" VerticalAlignment="Top"
                                           Fill="#FF00F0FF" Opacity="0" />
                                <Path x:Name="brkTL" Stroke="#FF00F0FF" StrokeThickness="1"
                                      Data="M 0,5 L 0,0 L 5,0"
                                      HorizontalAlignment="Left" VerticalAlignment="Top"
                                      Margin="2,2,0,0" Opacity="0" />
                                <Path x:Name="brkBR" Stroke="#FF00F0FF" StrokeThickness="1"
                                      Data="M 0,5 L 5,5 L 5,0"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                      Margin="0,0,2,2" Opacity="0" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <Border x:Name="glow" IsHitTestVisible="False"
                                BorderBrush="#FF00F0FF" BorderThickness="1"
                                CornerRadius="0" Margin="6,0,2,0" Opacity="0">
                            <Border.Effect>
                                <BlurEffect Radius="10" />
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#1500F0FF" />
                            <Setter TargetName="bg" Property="BorderBrush" Value="#5500F0FF" />
                            <Setter TargetName="rail" Property="Opacity" Value="0.6" />
                            <Setter TargetName="topAccent" Property="Opacity" Value="0.5" />
                            <Setter TargetName="glow" Property="Opacity" Value="0.45" />
                            <Setter Property="Foreground" Value="#FFD8EEF8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#2500F0FF" />
                            <Setter TargetName="rail" Property="Opacity" Value="1" />
                            <Setter TargetName="topAccent" Property="Opacity" Value="1" />
                            <Setter TargetName="brkTL" Property="Opacity" Value="1" />
                            <Setter TargetName="brkBR" Property="Opacity" Value="1" />
                            <Setter Property="Foreground" Value="#FF00F0FF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ NAV SECTION HEADER ═══════════ -->
    <Style x:Key="NavSectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF506070" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,10,0,4" />
    </Style>
    <Style x:Key="NavCloseBtn" TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="#FF506070" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Content" Value="&#x25BC;" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="cb" Background="Transparent" CornerRadius="2" Padding="2,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cb" Property="Background" Value="#33FF3000" />
                            <Setter Property="Foreground" Value="#FFFF3000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ PIN CHECKBOX ═══════════ -->
    <Style x:Key="PinCheck" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="pinBorder" Background="Transparent" CornerRadius="2" Padding="6,3" ToolTip="Pin">
                        <TextBlock x:Name="pinIcon" Text="&#x25CB;" FontSize="12" Foreground="#FF506070" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="pinIcon" Property="Text" Value="&#x25C9;" />
                            <Setter TargetName="pinIcon" Property="Foreground" Value="#FF00F0FF" />
                            <Setter TargetName="pinBorder" Property="Background" Value="#1F00F0FF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="pinBorder" Property="Background" Value="#1A00F0FF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slider implicit style is defined in /Styles/PhantomSlider.xaml (gradient Electric→Plasma per spec §4) -->

    <!-- ═══════════ COMBOBOX ═══════════ -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"       Value="{StaticResource BgInput}" />
        <Setter Property="Foreground"       Value="{StaticResource Accent}" />
        <Setter Property="BorderBrush"      Value="{StaticResource Border1}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="FontFamily"       Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize"         Value="11" />
        <Setter Property="FontWeight"       Value="SemiBold" />
        <Setter Property="Height"           Value="30" />
        <Setter Property="Cursor"           Value="Hand" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource Accent}" />
        <Setter Property="TextBlock.Foreground"   Value="{StaticResource Accent}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                TextElement.Foreground="{StaticResource Accent}"
                                TextBlock.Foreground="{StaticResource Accent}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False"
                                    TextElement.Foreground="{StaticResource Accent}"
                                    TextBlock.Foreground="{StaticResource Accent}" />
                                <TextBlock Grid.Column="1" Text="&#x25BE;" FontSize="9"
                                           Foreground="{StaticResource Accent}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <ToggleButton Grid.ColumnSpan="2" Focusable="False"
                                              IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press" Background="Transparent" BorderThickness="0"
                                              Cursor="Hand" />
                            </Grid>
                        </Border>
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                <Border Background="{StaticResource BgInput}" BorderBrush="{StaticResource Border2}"
                                        BorderThickness="1" CornerRadius="2"
                                        TextElement.Foreground="{StaticResource Accent}"
                                        TextBlock.Foreground="{StaticResource Accent}">
                                    <ScrollViewer SnapsToDevicePixels="True" Background="Transparent">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"           Value="Transparent" />
                    <Setter Property="Foreground"           Value="{StaticResource Accent}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="TextBlock.Foreground"   Value="{StaticResource Accent}" />
                    <Setter Property="FontFamily"           Value="{StaticResource MonoFont}" />
                    <Setter Property="FontWeight"           Value="SemiBold" />
                    <Setter Property="Padding"              Value="10,6" />
                    <Setter Property="FontSize"             Value="11" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ib" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        TextElement.Foreground="{StaticResource Accent}"
                                        TextBlock.Foreground="{StaticResource Accent}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      TextElement.Foreground="{StaticResource Accent}"
                                                      TextBlock.Foreground="{StaticResource Accent}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ib" Property="Background" Value="#1A00F0FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ib" Property="Background" Value="#3300F0FF" />
                                        <Setter Property="Foreground" Value="#FFB400FF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ TEXTBOX ═══════════ -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgInput}" />
        <Setter Property="Foreground" Value="{StaticResource TxtPri}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Height" Value="30" />
        <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
    </Style>

    <!-- ═══════════ CHECKBOX ═══════════ -->
    <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                            <Border x:Name="cbBox"
                                    Background="{StaticResource BgInput}"
                                    BorderBrush="{StaticResource Border2}"
                                    BorderThickness="1"
                                    CornerRadius="2" />
                            <Border x:Name="cbFill"
                                    Margin="2"
                                    Background="{StaticResource Accent}"
                                    CornerRadius="1"
                                    Opacity="0">
                                <Border.Effect>
                                    <BlurEffect Radius="3" />
                                </Border.Effect>
                            </Border>
                            <Path x:Name="cbCheck"
                                  Data="M 3,8 L 7,12 L 13,4"
                                  Stroke="#FF010308"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />
                        </Grid>
                        <ContentPresenter Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="cbFill"  Property="Opacity" Value="1" />
                            <Setter TargetName="cbCheck" Property="Visibility" Value="Visible" />
                            <Setter TargetName="cbBox"   Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cbBox" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ RADIOBUTTON ═══════════ -->
    <Style TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ═══════════ ACTION BUTTONS — Phantom ═══════════ -->
    <Style x:Key="BtnStart" TargetType="Button">
        <Setter Property="Background" Value="#FF03070F" />
        <Setter Property="Foreground" Value="#FF00F0FF" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="BorderBrush" Value="#FF00F0FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <Grid>
                                <Rectangle Height="1" VerticalAlignment="Top"
                                           Fill="#FF00F0FF" Opacity="0.5" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>
                        <Border x:Name="g" IsHitTestVisible="False"
                                BorderBrush="#FF00F0FF" BorderThickness="1" CornerRadius="2" Opacity="0">
                            <Border.Effect>
                                <BlurEffect Radius="10" />
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#1A00F0FF" />
                            <Setter TargetName="g" Property="Opacity" Value="0.8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#FF008C99" />
                            <Setter Property="Foreground" Value="#FF010308" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="BtnStop" TargetType="Button" BasedOn="{StaticResource BtnStart}">
        <Setter Property="Foreground" Value="#FFFF3000" />
        <Setter Property="BorderBrush" Value="#FFFF3000" />
    </Style>
    <Style x:Key="BtnSmall" TargetType="Button">
        <Setter Property="Background" Value="#FF03070F" />
        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#1A00F0FF" />
                            <Setter TargetName="b" Property="BorderBrush" Value="#FF00F0FF" />
                            <Setter Property="Foreground" Value="#FF00F0FF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ColorButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Margin" Value="0,0,5,0" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="{StaticResource Border2}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ SCROLLBAR ═══════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#8000F0FF" CornerRadius="0" Margin="1,0">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#FF00F0FF" BlurRadius="4" ShadowDepth="0" Opacity="0.5" />
                                                </Border.Effect>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ CARD WRAPPER — Phantom panel ═══════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelFillBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!-- ═══════════ PHANTOM BALLOON HOST — spec §7 ═══════════ -->
    <Style x:Key="Balloon" TargetType="Border">
        <Setter Property="Background" Value="#F203070F" />
        <Setter Property="BorderBrush" Value="#FF1E2E42" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Width" Value="320" />
        <Setter Property="Effect">
            <Setter.Value>
                <!-- Sombra leve para não estrangular o WPF software-rendered overlay -->
                <DropShadowEffect Color="Black" ShadowDepth="6" BlurRadius="14" Opacity="0.6" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Header bar do balão embedded (título + botão close) -->
    <Style x:Key="BalloonHeader" TargetType="Border">
        <Setter Property="Background" Value="#66000000" />
        <Setter Property="BorderBrush" Value="#FF162030" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <Style x:Key="BalloonTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF8AAABB" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="BalloonCloseBtn" TargetType="Button">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#FF1E2E42" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#FF506070" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Content" Value="✕" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#22FF3000"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFF3000"/>
                            <Setter Property="Foreground" Value="#FFFF3000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
