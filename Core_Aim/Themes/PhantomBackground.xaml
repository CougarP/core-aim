<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM BACKGROUND LAYERS
         A reusable hex grid DrawingBrush, plus orb / vignette templates
         to be layered in any window root grid.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ═══ HEX GRID (DrawingBrush, tiled) ══════════════════════════ -->
    <DrawingBrush x:Key="HexGridBrush"
                  TileMode="Tile"
                  Viewport="0,0,52,46"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Hexagon outline -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#1F00F0FF" Thickness="1"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry>
                            <PathFigure StartPoint="13,0" IsClosed="True">
                                <LineSegment Point="39,0"/>
                                <LineSegment Point="52,23"/>
                                <LineSegment Point="39,46"/>
                                <LineSegment Point="13,46"/>
                                <LineSegment Point="0,23"/>
                            </PathFigure>
                        </PathGeometry>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Center dot -->
                <GeometryDrawing Brush="#3300F0FF">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="26,23" RadiusX="0.8" RadiusY="0.8"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- A denser variant for small popups -->
    <DrawingBrush x:Key="HexGridBrushDense"
                  TileMode="Tile"
                  Viewport="0,0,32,28"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#1500F0FF" Thickness="1"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry>
                            <PathFigure StartPoint="8,0" IsClosed="True">
                                <LineSegment Point="24,0"/>
                                <LineSegment Point="32,14"/>
                                <LineSegment Point="24,28"/>
                                <LineSegment Point="8,28"/>
                                <LineSegment Point="0,14"/>
                            </PathFigure>
                        </PathGeometry>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- ═══ TEMPLATES FOR LAYERS ════════════════════════════════════
         Use these inside a ContentControl or directly as XAML in
         each window root grid. They are not controls — just snippets
         documented here for reference; the actual layering is done in
         each window. See LoginWindow.xaml / MainWindow.xaml.
         ═══════════════════════════════════════════════════════════════ -->

</ResourceDictionary>
