<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:Core_Aim.Converters">

    <!-- ═══════════════════════════════════════════════════════════════
         LEGACY MAIN STYLES — extracted from old MainWindow.Resources
         Purpose: keep current MainWindow tab content visually identical
         while we split it into UserControls under Views/Pages/.
         These styles will be progressively replaced by Phantom equivalents.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ═══════════ CONVERTERS ═══════════ -->
    <converters:AppStatusConverter x:Key="StatusConverter" />
    <converters:AppColorConverter x:Key="ColorConverter" />
    <converters:BoolToButtonColorConverter x:Key="BtnColor" />
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- ═══════════ PALETTE — Phantom Design Language V2.0 §10 tokens ═══════════ -->
    <!-- Cada brush abaixo aponta para um token Phantom oficial. NÃO introduzir hex
         offspec aqui — todas as Pages herdam destes tokens. -->
    <Color x:Key="CAccent">#00F0FF</Color>     <!-- Electric -->
    <Color x:Key="CAccentDim">#00B8CC</Color>  <!-- Electric escurecido -->
    <SolidColorBrush x:Key="Accent"      Color="{StaticResource CAccent}" />
    <SolidColorBrush x:Key="AccentDark"  Color="{StaticResource CAccentDim}" />
    <SolidColorBrush x:Key="AccentDim"   Color="#008090" />  <!-- Electric muito escuro -->
    <SolidColorBrush x:Key="BgApp"       Color="#010308" />  <!-- Void -->
    <SolidColorBrush x:Key="BgPanel"     Color="#03070F" />  <!-- Abyss -->
    <SolidColorBrush x:Key="BgCard"      Color="#060D1A" />  <!-- Panel -->
    <SolidColorBrush x:Key="BgInput"     Color="#060D1A" />  <!-- Panel -->
    <SolidColorBrush x:Key="BgHover"     Color="#0A1422" />  <!-- Panel hover -->
    <SolidColorBrush x:Key="BgNav"       Color="#03070F" />  <!-- Abyss -->
    <SolidColorBrush x:Key="ColorGreen"  Color="#00FF9D" />  <!-- Pulse -->
    <SolidColorBrush x:Key="ColorCyan"   Color="#80E8FF" />  <!-- Ice -->
    <SolidColorBrush x:Key="ColorRed"    Color="#FF3000" />  <!-- Inferno -->
    <SolidColorBrush x:Key="ColorAmber"  Color="#FFE000" />  <!-- Solar -->
    <SolidColorBrush x:Key="TxtPri"      Color="#D8EEF8" />  <!-- White -->
    <SolidColorBrush x:Key="TxtSec"      Color="#8AAABB" />  <!-- Text -->
    <SolidColorBrush x:Key="TxtDim"      Color="#506070" />  <!-- TextSub -->
    <SolidColorBrush x:Key="Border1"     Color="#162030" />  <!-- Line -->
    <SolidColorBrush x:Key="Border2"     Color="#1E2E42" />  <!-- Line2 -->

    <!-- ═══════════ WINDOW BUTTONS ═══════════ -->
    <Style x:Key="WinBtn" TargetType="Button">
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#506070" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#162030" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="WinBtnClose" TargetType="Button" BasedOn="{StaticResource WinBtn}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#CC2400" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ TEXT STYLES ═══════════ -->
    <Style x:Key="PLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="PValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="PValueG" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="{StaticResource ColorGreen}" />
    </Style>
    <Style x:Key="PValueA" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="{StaticResource ColorAmber}" />
    </Style>
    <Style x:Key="PValueB" TargetType="TextBlock" BasedOn="{StaticResource PValue}">
        <Setter Property="Foreground" Value="{StaticResource ColorCyan}" />
    </Style>
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>
    <Style x:Key="SubTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="9.5" />
        <Setter Property="Foreground" Value="{StaticResource TxtDim}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,12,0,8" />
    </Style>

    <!-- ═══════════ NAV TAB BUTTON ═══════════ -->
    <Style x:Key="NavTab" TargetType="Button">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="#304050" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Rectangle x:Name="indicator" Width="3" HorizontalAlignment="Left"
                                   Fill="{StaticResource Accent}" RadiusX="1.5" RadiusY="1.5"
                                   Margin="0,10" Visibility="Collapsed" />
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,4,6,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#0A1422" />
                            <Setter Property="Foreground" Value="#8AAABB" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="indicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="bg" Property="Background" Value="#060D1A" />
                            <Setter Property="Foreground" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="NavCloseBtn" TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="#506070" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Content" Value="&#x25BC;" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="cb" Background="Transparent" CornerRadius="4" Padding="2,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cb" Property="Background" Value="#162030" />
                            <Setter Property="Foreground" Value="{StaticResource ColorRed}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ PIN CHECKBOX ═══════════ -->
    <Style x:Key="PinCheck" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="pinBorder" Background="Transparent" CornerRadius="6" Padding="6,3" ToolTip="Pin">
                        <TextBlock x:Name="pinIcon" Text="&#x25CB;" FontSize="12" Foreground="#304050" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="pinIcon" Property="Text" Value="&#x25C9;" />
                            <Setter TargetName="pinIcon" Property="Foreground" Value="{StaticResource Accent}" />
                            <Setter TargetName="pinBorder" Property="Background" Value="#001A22" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="pinBorder" Property="Background" Value="#0A1422" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ SLIDER ═══════════ -->
    <Style TargetType="Slider">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Height" Value="18" />
        <Setter Property="AutoToolTipPlacement" Value="TopLeft" />
        <Setter Property="AutoToolTipPrecision" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton IsTabStop="False" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="3" Background="{StaticResource Accent}" CornerRadius="1.5" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton IsTabStop="False" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="3" Background="#162030" CornerRadius="1.5" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse x:Name="th" Width="13" Height="13"
                                                     Fill="{StaticResource Accent}"
                                                     Stroke="#010308" StrokeThickness="2" />
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="th" Property="Fill" Value="White" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ COMBOBOX ═══════════ -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource BgInput}" />
        <Setter Property="Foreground"      Value="{StaticResource TxtPri}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Border1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize"        Value="11.5" />
        <Setter Property="Height"          Value="30" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False" />
                                <TextBlock Grid.Column="1" Text="&#x25BE;" FontSize="9"
                                           Foreground="{StaticResource TxtSec}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <ToggleButton Grid.ColumnSpan="2" Focusable="False"
                                              IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press" Background="Transparent" BorderThickness="0"
                                              Cursor="Hand" />
                            </Grid>
                        </Border>
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                <Border Background="{StaticResource BgInput}" BorderBrush="{StaticResource Border2}"
                                        BorderThickness="1" CornerRadius="8">
                                    <ScrollViewer SnapsToDevicePixels="True" Background="Transparent">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"           Value="Transparent" />
                    <Setter Property="Foreground"           Value="{StaticResource TxtPri}" />
                    <Setter Property="Padding"              Value="10,6" />
                    <Setter Property="FontSize"             Value="11.5" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ib" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ib" Property="Background" Value="#162030" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ib" Property="Background" Value="#003344" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ TEXTBOX (legacy implicit) ═══════════ -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgInput}" />
        <Setter Property="Foreground" Value="{StaticResource TxtPri}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Height" Value="30" />
        <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
    </Style>

    <!-- ═══════════ CHECKBOX (legacy implicit) ═══════════ -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ═══════════ RADIOBUTTON (legacy implicit) ═══════════ -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ═══════════ ACTION BUTTONS ═══════════ -->
    <Style x:Key="BtnStart" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Accent}" />
        <Setter Property="Foreground" Value="#010308" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource AccentDark}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="BtnStop" TargetType="Button" BasedOn="{StaticResource BtnStart}">
        <Setter Property="Background" Value="{StaticResource ColorRed}" />
        <Setter Property="Foreground" Value="White" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#CC2400" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="BtnSmall" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgHover}" />
        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#1E2E42" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ColorButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Margin" Value="0,0,5,0" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="{StaticResource Border2}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ SCROLLBAR ═══════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#1E2E42" CornerRadius="2" Margin="1,0" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════ CARD WRAPPER ═══════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCard}" />
        <Setter Property="BorderBrush" Value="{StaticResource Border1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

</ResourceDictionary>
