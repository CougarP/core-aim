<UserControl x:Class="Core_Aim.Pages.TrainingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Core_Aim.ViewModels"
             xmlns:ctrl="clr-namespace:Core_Aim.Controls"
             Focusable="True">

    <UserControl.DataContext>
        <vm:TrainingViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Phantom Button -->
        <Style x:Key="PhBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF1A1E28"/>
            <Setter Property="Foreground" Value="#FFD8EEF8"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#FF1E2E42" BorderThickness="1"
                                Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2200F0FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF00F0FF"/>
                                <Setter Property="Foreground" Value="#FF00F0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3300F0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#FF0A0E14"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF101820"/>
                                <Setter Property="Foreground" Value="#FF3A4A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PhBtnGreen" TargetType="Button" BasedOn="{StaticResource PhBtn}">
            <Setter Property="Foreground" Value="#FF00FF9D"/>
        </Style>

        <Style x:Key="PhBtnOrange" TargetType="Button" BasedOn="{StaticResource PhBtn}">
            <Setter Property="Foreground" Value="#FFFF8800"/>
        </Style>

        <Style x:Key="PhBtnRed" TargetType="Button" BasedOn="{StaticResource PhBtn}">
            <Setter Property="Foreground" Value="#FFFF3000"/>
        </Style>

        <Style x:Key="PhCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FF8AAABB"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF506070"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Phantom Slider -->
        <Style x:Key="PhSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="5"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="5"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FF010308">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- LEFT — Canvas area (Void bg, same as CoreAim) -->
        <!-- ═══════════════════════════════════════ -->
        <Grid x:Name="CanvasArea" Grid.Column="0" ClipToBounds="True"
              Cursor="None"
              MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
              MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
              MouseRightButtonDown="Canvas_MouseRightButtonDown"
              MouseMove="Canvas_MouseMove"
              MouseLeave="Canvas_MouseLeave"
              MouseWheel="Canvas_MouseWheel"
              SizeChanged="CanvasArea_SizeChanged">

            <!-- CoreAim background (cached to bitmap — zero per-frame blur cost) -->
            <Grid IsHitTestVisible="False">
                <Grid.CacheMode><BitmapCache/></Grid.CacheMode>
                <Rectangle Fill="{StaticResource VoidBrush}"/>
                <Rectangle Fill="{StaticResource HexGridBrush}" Opacity="0.50"/>
                <Ellipse Width="700" Height="700"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-220,-260,0,0"
                         Fill="{StaticResource ElectricOrbBrush}" Opacity="0.30">
                    <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="640" Height="640"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-200,-220"
                         Fill="{StaticResource PlasmaOrbBrush}" Opacity="0.22">
                    <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                </Ellipse>
                <Rectangle Fill="{StaticResource VignetteBrush}"/>
                <Rectangle Opacity="0.04">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute" Stretch="None">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#FF00F0FF">
                                    <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,4,1"/></GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>

            <!-- Animated geometric shapes (same IdlePreview as CoreAim) -->
            <ctrl:IdlePreview x:Name="IdleAnim" IsHitTestVisible="False"/>

            <!-- Image canvas: sized to image only, centered, dark bg -->
            <Grid x:Name="CanvasHost" Background="#FF010308"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  ClipToBounds="True"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="ZoomTranslate" X="0" Y="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <Image x:Name="CanvasImage" Source="{Binding DisplayImage}"
                       Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"/>

                <Canvas x:Name="BBoxCanvas" IsHitTestVisible="False"/>
            </Grid>

            <!-- Drag rect (screen space overlay) -->
            <Border x:Name="DragRect" Visibility="Collapsed" IsHitTestVisible="False"
                    BorderThickness="1" BorderBrush="#FF00F0FF" Background="#1A00F0FF"
                    HorizontalAlignment="Left" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#FF00F0FF" ShadowDepth="0" BlurRadius="4" Opacity="0.4"/>
                </Border.Effect>
            </Border>

            <!-- Crosshair overlay added in code-behind (custom OnRender, zero lag) -->
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- RIGHT — Controls panel                  -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Column="1" Background="#FF060A12"
                BorderBrush="#FF1E2E42" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,10">

                    <!-- BACK button -->
                    <Button Content="◄ BACK" Style="{StaticResource PhBtn}" Padding="8,5"
                            HorizontalAlignment="Left" Margin="0,0,0,10"
                            Click="BackBtn_Click"/>

                    <!-- ── COMMANDS ── -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="COMMANDS"/>
                    <UniformGrid Columns="3" Margin="0,0,0,4">
                        <Button Content="Pasta" Style="{StaticResource PhBtn}" Padding="0,7"
                                Command="{Binding OpenFolderCommand}" Margin="0,0,3,0"/>
                        <Button Content="Modelo" Style="{StaticResource PhBtn}" Padding="0,7"
                                Command="{Binding LoadModelCommand}" Margin="3,0,3,0"/>
                        <Button Content="Salvar" Style="{StaticResource PhBtnGreen}" Padding="0,7"
                                Command="{Binding SaveCommand}" Margin="3,0,0,0"/>
                    </UniformGrid>
                    <UniformGrid Columns="2" Margin="0,4,0,4">
                        <Button Content="Criar Classes" Style="{StaticResource PhBtn}" Padding="0,7"
                                Command="{Binding EditClassesCommand}" Margin="0,0,3,0"/>
                        <Button Content="Limpar Dataset" Style="{StaticResource PhBtnOrange}" Padding="0,7"
                                Command="{Binding CleanDatasetCommand}" Margin="3,0,0,0"/>
                    </UniformGrid>

                    <!-- ── AUTO-LABEL ── -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="AUTO-LABEL" Margin="0,8,0,6"/>

                    <!-- Confidence threshold -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Conf:" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF8AAABB" VerticalAlignment="Center" Width="36"/>
                        <Slider Width="140" VerticalAlignment="Center" Focusable="False"
                                Minimum="5" Maximum="100" TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ConfThresholdInt}" x:Name="ConfSlider"/>
                        <TextBlock Text="{Binding ConfThresholdPercent}" FontFamily="{StaticResource MonoFont}"
                                   FontSize="9" Foreground="#FF00F0FF" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Label buttons -->
                    <UniformGrid Columns="2" Margin="0,4,0,10">
                        <Button Content="Label This" Style="{StaticResource PhBtnGreen}" Padding="0,7"
                                Command="{Binding LabelThisImageCommand}" Margin="0,0,3,0"/>
                        <!-- Label All: visible when NOT labeling -->
                        <Button x:Name="BtnLabelAll" Content="Label All" Style="{StaticResource PhBtnRed}" Padding="0,7"
                                Command="{Binding LabelAllImagesCommand}" Margin="3,0,0,0"/>
                        <!-- Stop: visible when labeling -->
                        <Button x:Name="BtnStopLabel" Content="STOP" Padding="0,7" Margin="3,0,0,0"
                                Command="{Binding StopLabelCommand}" Visibility="Collapsed">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PhBtnOrange}"/>
                            </Button.Style>
                        </Button>
                    </UniformGrid>

                    <!-- ── DISPLAY ── -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="DISPLAY"/>
                    <CheckBox Content="Show Labels" Style="{StaticResource PhCheck}"
                              IsChecked="{Binding ShowLabels}"/>
                    <CheckBox Content="Show Crosshair" Style="{StaticResource PhCheck}"
                              IsChecked="{Binding ShowCrosshair}"/>

                    <!-- Display scale slider -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Scale:" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF8AAABB" VerticalAlignment="Center" Width="42"/>
                        <Slider Width="140" VerticalAlignment="Center" Focusable="False"
                                Minimum="100" Maximum="200" TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                Value="{Binding DisplayScale}"
                                x:Name="ScaleSlider"/>
                        <TextBlock Text="{Binding DisplayScaleText}" FontFamily="{StaticResource MonoFont}"
                                   FontSize="9" Foreground="#FF00F0FF" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Zoom reset -->
                    <Button Content="Reset Zoom" Style="{StaticResource PhBtn}" Padding="6,4"
                            HorizontalAlignment="Left" Margin="0,6,0,10"
                            Command="{Binding ResetZoomCommand}" FontSize="8"/>

                    <!-- ── IMAGES ── -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="IMAGES"/>
                    <ListBox x:Name="ImageListBox" Height="180"
                             Background="#FF0A1018" Foreground="#FF8AAABB"
                             BorderBrush="#FF1E2E42" BorderThickness="1"
                             FontFamily="{StaticResource MonoFont}" FontSize="9"
                             ItemsSource="{Binding Images}"
                             SelectedIndex="{Binding ImageIndex, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="#FF8AAABB"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1700F0FF"/>
                                        <Setter Property="Foreground" Value="#FF00F0FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0A00F0FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="5" Height="5" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#FFFFE000"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasLabel}" Value="True">
                                                        <Setter Property="Fill" Value="#FF00FF9D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding FileName}" FontFamily="{StaticResource MonoFont}" FontSize="9"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- ── CLASSES ── -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="CLASSES" Margin="0,10,0,6"/>
                    <ItemsControl ItemsSource="{Binding Classes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1" Cursor="Hand"
                                      MouseLeftButtonDown="ClassItem_Click"
                                      Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                              Margin="0,0,4,0" VerticalAlignment="Center" Focusable="False"/>
                                    <TextBlock Grid.Column="1" Text="◆" FontSize="9"
                                               Foreground="{Binding Color}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Name}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="10"
                                               Foreground="{Binding Color}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Id}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="8"
                                               Foreground="#FF506070" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── SHORTCUTS ── -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="SHORTCUTS" Margin="0,14,0,6"/>
                    <Border Background="#FF0A1018" BorderBrush="#FF1E2E42" BorderThickness="1" Padding="8,6">
                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="8.5"
                                   Foreground="#FF506070" TextWrapping="Wrap" LineHeight="16">
                            <Run Text="Left-drag" Foreground="#FF00F0FF"/> — Draw bbox<LineBreak/>
                            <Run Text="Right-click" Foreground="#FF00F0FF"/> — Delete bbox<LineBreak/>
                            <Run Text="Scroll" Foreground="#FF00F0FF"/> — Zoom at cursor<LineBreak/>
                            <Run Text="A / ←" Foreground="#FF00F0FF"/> — Prev image<LineBreak/>
                            <Run Text="D / →" Foreground="#FF00F0FF"/> — Next image<LineBreak/>
                            <Run Text="W / S" Foreground="#FF00F0FF"/> — Change class<LineBreak/>
                            <Run Text="C" Foreground="#FF00F0FF"/> — Clear boxes<LineBreak/>
                            <Run Text="R" Foreground="#FF00F0FF"/> — Label this image<LineBreak/>
                            <Run Text="Ctrl+S" Foreground="#FF00F0FF"/> — Save labels
                        </TextBlock>
                    </Border>

                    <!-- ── STATUS ── -->
                    <Border Margin="0,10,0,0" Padding="6,4" Background="#FF0A1018"
                            BorderBrush="#FF1E2E42" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF00F0FF">
                                <Run Text="{Binding ImageCounter, Mode=OneWay}"/>
                                <Run Text=" · " Foreground="#FF506070"/>
                                <Run Text="{Binding ImageDimensions, Mode=OneWay}" Foreground="#FF506070"/>
                                <Run Text=" · " Foreground="#FF506070"/>
                                <Run Text="{Binding Boxes.Count, Mode=OneWay}" Foreground="#FF00FF9D"/>
                                <Run Text=" boxes" Foreground="#FF506070"/>
                            </TextBlock>
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="8"
                                       Foreground="#FF506070" Margin="0,2,0,0">
                                <Run Text="Model: "/><Run Text="{Binding ModelStatus, Mode=OneWay}" Foreground="#FF8AAABB"/>
                            </TextBlock>
                            <TextBlock Text="{Binding StatusText}" FontFamily="{StaticResource MonoFont}"
                                       FontSize="8" Foreground="#FF506070" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- ══════════════ TRAINING ══════════════ -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="TRAINING" Margin="0,14,0,6"/>

                    <!-- Status -->
                    <Border Background="#FF0A1018" BorderBrush="#FF1E2E42" BorderThickness="1"
                            Padding="8,5" Margin="0,0,0,6">
                        <TextBlock Text="{Binding TrainStatus}" FontFamily="{StaticResource MonoFont}"
                                   FontSize="8" Foreground="#FF8AAABB" TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                    </Border>

                    <!-- Val Split -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Val %:" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF8AAABB" VerticalAlignment="Center" Width="42"/>
                        <Slider Width="120" VerticalAlignment="Center" Focusable="False"
                                Minimum="5" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True"
                                Value="{Binding TrainValPercent}"/>
                        <TextBlock Text="{Binding TrainValPercent, StringFormat={}{0}%}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF00F0FF" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Prepare Dataset -->
                    <Button Content="Preparar Dataset" Style="{StaticResource PhBtnGreen}" Padding="0,7"
                            Command="{Binding PrepareDatasetCommand}" Margin="0,4,0,8"
                            HorizontalAlignment="Stretch"/>

                    <!-- Epochs -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Epochs:" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF8AAABB" VerticalAlignment="Center" Width="50"/>
                        <Slider Width="108" VerticalAlignment="Center" Focusable="False"
                                Minimum="10" Maximum="500" TickFrequency="10" IsSnapToTickEnabled="True"
                                Value="{Binding TrainEpochs}"/>
                        <TextBlock Text="{Binding TrainEpochs}" FontFamily="{StaticResource MonoFont}"
                                   FontSize="9" Foreground="#FFFFE000" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Batch Size -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Batch:" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF8AAABB" VerticalAlignment="Center" Width="50"/>
                        <ComboBox SelectedIndex="{Binding TrainBatchIndex}" Width="80"
                                  FontFamily="{StaticResource MonoFont}" FontSize="9" Focusable="False">
                            <ComboBoxItem Content="Auto"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="8"/>
                            <ComboBoxItem Content="16"/>
                            <ComboBoxItem Content="32"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Image Size -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="ImgSz:" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF8AAABB" VerticalAlignment="Center" Width="50"/>
                        <ComboBox SelectedIndex="{Binding TrainImgSizeIndex}" Width="80"
                                  FontFamily="{StaticResource MonoFont}" FontSize="9" Focusable="False">
                            <ComboBoxItem Content="320"/>
                            <ComboBoxItem Content="416"/>
                            <ComboBoxItem Content="480"/>
                            <ComboBoxItem Content="640"/>
                            <ComboBoxItem Content="960"/>
                            <ComboBoxItem Content="1280"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Base Model -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Base:" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF8AAABB" VerticalAlignment="Center" Width="50"/>
                        <ComboBox SelectedIndex="{Binding TrainBaseModelIndex}" Width="120"
                                  FontFamily="{StaticResource MonoFont}" FontSize="9" Focusable="False">
                            <ComboBoxItem Content="yolov8n.pt"/>
                            <ComboBoxItem Content="yolov8s.pt"/>
                            <ComboBoxItem Content="yolov8m.pt"/>
                            <ComboBoxItem Content="yolov8l.pt"/>
                            <ComboBoxItem Content="yolo11n.pt"/>
                            <ComboBoxItem Content="yolo11s.pt"/>
                            <ComboBoxItem Content="yolo11m.pt"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Train / Stop -->
                    <UniformGrid Columns="2" Margin="0,0,0,6">
                        <Button x:Name="BtnTrain" Content="TREINAR" Style="{StaticResource PhBtnGreen}" Padding="0,8"
                                Command="{Binding StartTrainingCommand}" Margin="0,0,3,0"/>
                        <Button x:Name="BtnStopTrain" Content="PARAR" Style="{StaticResource PhBtnRed}" Padding="0,8"
                                Command="{Binding StopTrainingCommand}" Margin="3,0,0,0" Visibility="Collapsed"/>
                    </UniformGrid>

                    <!-- Metrics -->
                    <Border x:Name="TrainMetricsPanel" Background="#FF0A1018" BorderBrush="#FF1E2E42"
                            BorderThickness="1" Padding="8,6" Margin="0,0,0,6" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF00F0FF">
                                <Run Text="Epoch: "/><Run Text="{Binding TrainEpochText, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="#FF506070" Margin="0,2,0,0">
                                <Run Text="Box: "/><Run Text="{Binding TrainLossBox, StringFormat=F4, Mode=OneWay}" Foreground="#FFFFE000"/>
                                <Run Text="  Cls: "/><Run Text="{Binding TrainLossCls, StringFormat=F4, Mode=OneWay}" Foreground="#FFB400FF"/>
                                <Run Text="  Dfl: "/><Run Text="{Binding TrainLossDfl, StringFormat=F4, Mode=OneWay}" Foreground="#FF00F0FF"/>
                            </TextBlock>
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="#FF506070" Margin="0,2,0,0">
                                <Run Text="mAP50: "/><Run Text="{Binding TrainMap50, StringFormat=F3, Mode=OneWay}" Foreground="#FF00FF9D"/>
                                <Run Text="  mAP50-95: "/><Run Text="{Binding TrainMap5095, StringFormat=F3, Mode=OneWay}" Foreground="#FF00FF9D"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Log -->
                    <TextBox x:Name="TrainLogBox" Text="{Binding TrainLog, Mode=OneWay}"
                             IsReadOnly="True" Height="100" Visibility="Collapsed"
                             FontFamily="{StaticResource MonoFont}" FontSize="7"
                             Background="#FF0A1018" Foreground="#FF506070"
                             BorderBrush="#FF1E2E42" BorderThickness="1"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Padding="4,3" Margin="0,0,0,6" Focusable="False"/>

                    <!-- Install Model -->
                    <Button x:Name="BtnInstallModel" Content="Instalar Modelo" Style="{StaticResource PhBtnGreen}" Padding="0,7"
                            Command="{Binding InstallModelCommand}" Margin="0,0,0,4"
                            HorizontalAlignment="Stretch" Visibility="Collapsed"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
