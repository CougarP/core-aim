<UserControl x:Class="Core_Aim.Pages.DetectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Core_Aim.Controls"
             xmlns:loc="clr-namespace:Core_Aim.Services"
             xmlns:converters="clr-namespace:Core_Aim.Converters">
    <UserControl.Resources>
        <converters:AppStatusConverter x:Key="StatusConverter"/>
        <converters:AppColorConverter x:Key="ColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="16,14,14,14">
        <CheckBox IsChecked="{Binding IsDETPinned, Mode=TwoWay}" HorizontalAlignment="Right" Margin="0,0,0,4" Cursor="Hand" Style="{StaticResource PinCheck}" />
        <TextBlock Text="{loc:Loc DetMode}" Style="{StaticResource SectionTitle}" />

        <!-- Detection Mode -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="▸ MODO" Style="{StaticResource SubsectionLabel}" />
                <ComboBox SelectedIndex="{Binding SettingsViewModel.PixelBotMode, Mode=TwoWay}">
                    <ComboBoxItem Content="{loc:Loc DM0}" />
                    <ComboBoxItem Content="{loc:Loc DM1}" />
                    <ComboBoxItem Content="{loc:Loc DM2}" />
                    <ComboBoxItem Content="{loc:Loc DM3}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Target Offset -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="▸ TARGET OFFSET" Style="{StaticResource SubsectionLabel}" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <RadioButton Content="YOLO (Body)" IsChecked="{Binding SettingsViewModel.IsPlayerMode, Mode=TwoWay}" GroupName="TgtMode" Foreground="#FF10B981" FontWeight="SemiBold" />
                    <RadioButton Grid.Column="1" Content="PixelBot (Icon)" IsChecked="{Binding SettingsViewModel.IsIconMode, Mode=TwoWay}" GroupName="TgtMode" Foreground="#FFF59E0B" FontWeight="SemiBold" />
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Offset" Style="{StaticResource PLabel}" />
                    <TextBlock Grid.Column="1" Text="{Binding SettingsViewModel.AimOffsetY, StringFormat=N0}" Style="{StaticResource PValueA}" />
                </Grid>
                <ctrl:NumericSlider Minimum="0" Maximum="100" SmallChange="1" LargeChange="5" Value="{Binding SettingsViewModel.AimOffsetY, Mode=TwoWay}" Tint="#FFFFE000" />
            </StackPanel>
        </Border>

        <!-- PixelBot (Color) -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="▸ PIXEL BOT" Style="{StaticResource SubsectionLabel}" />
                <Button Content="{loc:Loc ResetDefaults}" Command="{Binding SettingsViewModel.ResetPixelBotCommand}" Margin="0,0,0,10" Padding="6,4" FontSize="10.5" Background="#181C24" Foreground="#94A3B8" BorderBrush="{StaticResource Border2}" HorizontalAlignment="Stretch" />
                <StackPanel Visibility="{Binding SettingsViewModel.PixelBotIsActive, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="8" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc TargetColor}" Style="{StaticResource PLabel}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding SettingsViewModel.PixelBotColorHex}" FontSize="10" FontFamily="{StaticResource MonoFont}" Foreground="{Binding SettingsViewModel.PixelBotColorBrush}" VerticalAlignment="Center" />
                        <Button Grid.Column="3" Command="{Binding SettingsViewModel.PickPixelBotColorCommand}" Width="36" Height="22" Background="{Binding SettingsViewModel.PixelBotColorBrush}" BorderBrush="{StaticResource Border2}" BorderThickness="1" Cursor="Hand" />
                    </Grid>
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc ColorTolerance}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotColorTolerance}" Style="{StaticResource PValueA}" /></Grid>
                    <ctrl:NumericSlider Minimum="1" Maximum="60" SmallChange="1" LargeChange="5" Value="{Binding SettingsViewModel.PixelBotColorTolerance, Mode=TwoWay}" Tint="#FFFFE000" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc MinArea}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotMinArea}" Style="{StaticResource PValue}" /></Grid>
                    <ctrl:NumericSlider Minimum="1" Maximum="500" SmallChange="1" LargeChange="25" Value="{Binding SettingsViewModel.PixelBotMinArea, Mode=TwoWay}" Tint="#FF00F0FF" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc MaxArea}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotMaxArea}" Style="{StaticResource PValue}" /></Grid>
                    <ctrl:NumericSlider Minimum="50" Maximum="5000" SmallChange="10" LargeChange="100" Value="{Binding SettingsViewModel.PixelBotMaxArea, Mode=TwoWay}" Tint="#FF00F0FF" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc MinAspect}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotMinAspectRatio, StringFormat=F2}" Style="{StaticResource PValueP}" /></Grid>
                    <ctrl:NumericSlider Minimum="0.0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1" Value="{Binding SettingsViewModel.PixelBotMinAspectRatio, Mode=TwoWay}" Tint="#FFB400FF" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc MinSolidity}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotMinSolidity, StringFormat=F2}" Style="{StaticResource PValueP}" /></Grid>
                    <ctrl:NumericSlider Minimum="0.0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1" Value="{Binding SettingsViewModel.PixelBotMinSolidity, Mode=TwoWay}" Tint="#FFB400FF" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc MinCircularity}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotMinCircularity, StringFormat=F2}" Style="{StaticResource PValueP}" /></Grid>
                    <ctrl:NumericSlider Minimum="0.0" Maximum="1.0" SmallChange="0.05" LargeChange="0.1" Value="{Binding SettingsViewModel.PixelBotMinCircularity, Mode=TwoWay}" Tint="#FFB400FF" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc SatMin}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotSatMin}" Style="{StaticResource PValueB}" /></Grid>
                    <ctrl:NumericSlider Minimum="0" Maximum="255" SmallChange="5" LargeChange="20" Value="{Binding SettingsViewModel.PixelBotSatMin, Mode=TwoWay}" Tint="#FF80E8FF" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc ValMin}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotValMin}" Style="{StaticResource PValueB}" /></Grid>
                    <ctrl:NumericSlider Minimum="0" Maximum="255" SmallChange="5" LargeChange="20" Value="{Binding SettingsViewModel.PixelBotValMin, Mode=TwoWay}" Tint="#FF80E8FF" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc PersistRadius}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotPersistRadius}" Style="{StaticResource PValueG}" /></Grid>
                    <ctrl:NumericSlider Minimum="0" Maximum="200" SmallChange="1" LargeChange="10" Value="{Binding SettingsViewModel.PixelBotPersistRadius, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc PersistFrames}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PixelBotMaxFramesLost}" Style="{StaticResource PValueG}" /></Grid>
                    <ctrl:NumericSlider Minimum="0" Maximum="30" SmallChange="1" LargeChange="3" Value="{Binding SettingsViewModel.PixelBotMaxFramesLost, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                </StackPanel>
            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
