<UserControl x:Class="Core_Aim.Pages.TriggerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Core_Aim.Controls"
             xmlns:loc="clr-namespace:Core_Aim.Services"
             xmlns:converters="clr-namespace:Core_Aim.Converters">
    <UserControl.Resources>
        <converters:AppStatusConverter x:Key="StatusConverter"/>
        <converters:AppColorConverter x:Key="ColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="16,14,14,14">
        <CheckBox IsChecked="{Binding IsTRGPinned, Mode=TwoWay}" HorizontalAlignment="Right" Margin="0,0,0,4" Cursor="Hand" Style="{StaticResource PinCheck}" />
        <TextBlock Text="{loc:Loc Trigger}" Style="{StaticResource SectionTitle}" />

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="{loc:Loc TriggerLabel}" Style="{StaticResource PLabel}" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding SettingsViewModel.TriggerLabels}" SelectedIndex="{Binding SettingsViewModel.SelectedTrigger, Mode=TwoWay}" Margin="0,0,0,10" />
                <TextBlock Text="{loc:Loc InferenceMode}" Style="{StaticResource PLabel}" Margin="0,0,0,6" />
                <ComboBox SelectedIndex="{Binding SettingsViewModel.SelectedInferenceMode, Mode=TwoWay}">
                    <ComboBoxItem Content="{loc:Loc IM0}" />
                    <ComboBoxItem Content="{loc:Loc IM1}" />
                    <ComboBoxItem Content="{loc:Loc IM2}" />
                    <ComboBoxItem Content="{loc:Loc IM3}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Macros Titan (TT2 only) — movido de DetectionPage para TriggerPage -->
        <Border Visibility="{Binding SettingsViewModel.IsTitanSelected, Converter={StaticResource BoolToVis}}"
                Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="▸ MACROS TITAN" Style="{StaticResource SubsectionLabel}" />
                <UniformGrid Columns="2" Margin="0,0,0,6">
                    <CheckBox Content="Rapid Fire" IsChecked="{Binding SettingsViewModel.MacroRapidFire}" Margin="0,0,0,4" />
                    <CheckBox Content="Anti-Recoil" IsChecked="{Binding SettingsViewModel.MacroAntiRecoil}" Margin="0,0,0,4" />
                    <CheckBox Content="Drop Shot" IsChecked="{Binding SettingsViewModel.MacroDropShot}" Margin="0,0,0,4" />
                    <CheckBox Content="Crouch Peek" IsChecked="{Binding SettingsViewModel.MacroCrouchPeek}" Margin="0,0,0,4" />
                    <CheckBox Content="Tac Sprint" IsChecked="{Binding SettingsViewModel.MacroTacSprint}" Margin="0,0,0,4" />
                    <CheckBox Content="Slide Cancel" IsChecked="{Binding SettingsViewModel.MacroSlideCancel}" Margin="0,0,0,4" />
                    <CheckBox Content="Auto Ping" IsChecked="{Binding SettingsViewModel.MacroAutoPing}" Margin="0,0,0,4" />
                    <CheckBox Content="Jump Shot" IsChecked="{Binding SettingsViewModel.MacroJumpShot}" Margin="0,0,0,4" />
                    <CheckBox Content="Bunny Hop" IsChecked="{Binding SettingsViewModel.MacroBunnyHop}" Margin="0,0,0,4" />
                    <CheckBox Content="Quickscope" IsChecked="{Binding SettingsViewModel.MacroQuickscope}" Margin="0,0,0,4" />
                    <CheckBox Content="Auto Breath" IsChecked="{Binding SettingsViewModel.MacroAutoBreath}" Margin="0,0,0,4" />
                    <CheckBox Content="Auto Reload" IsChecked="{Binding SettingsViewModel.MacroAutoReload}" Margin="0,0,0,4" />
                    <CheckBox Content="Auto Melee" IsChecked="{Binding SettingsViewModel.MacroAutoMelee}" Margin="0,0,0,4" />
                    <CheckBox Content="Auto ADS" IsChecked="{Binding SettingsViewModel.MacroAutoADS}" Margin="0,0,0,4" />
                    <CheckBox Content="Hair Trigger" IsChecked="{Binding SettingsViewModel.MacroHairTrigger}" Margin="0,0,0,4" />
                    <CheckBox Content="Strafe Shot" IsChecked="{Binding SettingsViewModel.MacroStrafeShot}" Margin="0,0,0,4" />
                    <CheckBox Content="Cook Protect" IsChecked="{Binding SettingsViewModel.MacroCookProtection}" Margin="0,0,0,4" />
                    <CheckBox Content="DeadZone Off" IsChecked="{Binding SettingsViewModel.MacroDeadZoneRemoval}" Margin="0,0,0,4" />
                </UniformGrid>

                <!-- Stick Override -->
                <Border BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0" Margin="0,4,0,8" Padding="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="▸ STICK OVERRIDE" Style="{StaticResource SubsectionLabel}" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc PlayerBlendLbl}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.PlayerBlend, StringFormat=P0}" Style="{StaticResource PValueG}" /></Grid>
                        <ctrl:NumericSlider Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" Value="{Binding SettingsViewModel.PlayerBlend, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc DisableAiThreshold}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.DisableOnMove, StringFormat=F0}" Style="{StaticResource PValueA}" /></Grid>
                        <ctrl:NumericSlider Minimum="50" Maximum="100" SmallChange="1" LargeChange="5" Value="{Binding SettingsViewModel.DisableOnMove, Mode=TwoWay}" Tint="#FFFFE000" />
                    </StackPanel>
                </Border>

                <!-- Macro Adjustments -->
                <Border BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="▸ MACRO ADJUSTMENTS" Style="{StaticResource SubsectionLabel}" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc ArVertical}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.MacroArVertical, StringFormat=F1}" Style="{StaticResource PValueG}" /></Grid>
                        <ctrl:NumericSlider Minimum="0" Maximum="50" SmallChange="0.5" LargeChange="5" Value="{Binding SettingsViewModel.MacroArVertical, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc ArHorizontal}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.MacroArHorizontal, StringFormat=F1}" Style="{StaticResource PValueG}" /></Grid>
                        <ctrl:NumericSlider Minimum="-50" Maximum="50" SmallChange="0.5" LargeChange="5" Value="{Binding SettingsViewModel.MacroArHorizontal, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc RapidFireSpeed}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.MacroRapidFireMs, StringFormat=F0}" Style="{StaticResource PValueA}" /></Grid>
                        <ctrl:NumericSlider Minimum="20" Maximum="100" SmallChange="1" LargeChange="10" Value="{Binding SettingsViewModel.MacroRapidFireMs, Mode=TwoWay}" Tint="#FFFFE000" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc QuickscopeDelay}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.QuickscopeDelay, StringFormat=F0}" Style="{StaticResource PValueG}" /></Grid>
                        <ctrl:NumericSlider Minimum="200" Maximum="1000" SmallChange="10" LargeChange="50" Value="{Binding SettingsViewModel.QuickscopeDelay, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc JumpShotDelay}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.JumpShotDelay, StringFormat=F0}" Style="{StaticResource PValueG}" /></Grid>
                        <ctrl:NumericSlider Minimum="100" Maximum="800" SmallChange="10" LargeChange="50" Value="{Binding SettingsViewModel.JumpShotDelay, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc BunnyHopDelay}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.BunnyHopDelay, StringFormat=F0}" Style="{StaticResource PValueG}" /></Grid>
                        <ctrl:NumericSlider Minimum="40" Maximum="300" SmallChange="5" LargeChange="20" Value="{Binding SettingsViewModel.BunnyHopDelay, Mode=TwoWay}" Tint="#FF00FF9D" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc StrafePower}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.StrafePower, StringFormat=F0}" Style="{StaticResource PValueA}" /></Grid>
                        <ctrl:NumericSlider Minimum="10" Maximum="100" SmallChange="1" LargeChange="10" Value="{Binding SettingsViewModel.StrafePower, Mode=TwoWay}" Tint="#FFFFE000" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
