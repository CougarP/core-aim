<UserControl x:Class="Core_Aim.Pages.MonitorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Core_Aim.Controls"
             xmlns:loc="clr-namespace:Core_Aim.Services"
             xmlns:converters="clr-namespace:Core_Aim.Converters">
    <UserControl.Resources>
        <converters:AppStatusConverter x:Key="StatusConverter"/>
        <converters:AppColorConverter x:Key="ColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="16,14,14,14">
        <CheckBox IsChecked="{Binding IsMONPinned, Mode=TwoWay}" HorizontalAlignment="Right" Margin="0,0,0,4" Cursor="Hand" Style="{StaticResource PinCheck}" />
        <TextBlock Text="{loc:Loc Monitor}" Style="{StaticResource SectionTitle}" />

        <!-- TITAN TWO PANEL -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding SettingsViewModel.IsTitanSelected, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Stick Visualizers -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="L Stick" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                        <ctrl:StickVisualizer Width="120" Height="120"
                            StickX="{Binding MonitorViewModel.StickLX}"
                            StickY="{Binding MonitorViewModel.StickLY}"
                            ShowAi="False"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock Text="{Binding MonitorViewModel.StickLX, StringFormat=X:{0}}" Foreground="{StaticResource Accent}" FontSize="9" FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding MonitorViewModel.StickLY, StringFormat=Y:{0}}" Foreground="{StaticResource Accent}" FontSize="9" FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="R Stick + AI" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                        <ctrl:StickVisualizer Width="120" Height="120"
                            StickX="{Binding MonitorViewModel.StickRX}"
                            StickY="{Binding MonitorViewModel.StickRY}"
                            AiX="{Binding MonitorViewModel.AiRX}"
                            AiY="{Binding MonitorViewModel.AiRY}"
                            ShowAi="True"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock Text="{Binding MonitorViewModel.StickRX, StringFormat=X:{0}}" Foreground="{StaticResource Accent}" FontSize="9" FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding MonitorViewModel.StickRY, StringFormat=Y:{0}}" Foreground="{StaticResource Accent}" FontSize="9" FontFamily="{StaticResource MonoFont}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding MonitorViewModel.AiRX, StringFormat=AI:{0}}" Foreground="{StaticResource ColorGreen}" FontSize="9" FontFamily="{StaticResource MonoFont}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding MonitorViewModel.AiRY, StringFormat={}{0}}" Foreground="{StaticResource ColorGreen}" FontSize="9" FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Triggers LT / RT -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LT " FontSize="10" FontWeight="Bold" Foreground="{StaticResource ColorRed}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MonitorViewModel.LTValue, StringFormat={}{0}%}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ColorRed}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="RT " FontSize="10" FontWeight="Bold" Foreground="{StaticResource ColorCyan}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MonitorViewModel.RTValue, StringFormat={}{0}%}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ColorCyan}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Device Info -->
                <Border Background="#0D1017" CornerRadius="8" Padding="10,8" Margin="0,0,0,8" BorderBrush="{StaticResource Border1}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Device" FontSize="9" Foreground="#64748B" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MonitorViewModel.DeviceProduct}" FontSize="9" Foreground="#E2E8F0" FontFamily="{StaticResource MonoFont}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Maker" FontSize="9" Foreground="#64748B" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MonitorViewModel.DeviceManufacturer}" FontSize="9" Foreground="#E2E8F0" FontFamily="{StaticResource MonoFont}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Serial" FontSize="9" Foreground="#64748B" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MonitorViewModel.DeviceSerial}" FontSize="9" Foreground="#E2E8F0" FontFamily="{StaticResource MonoFont}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="FW" FontSize="9" Foreground="#64748B" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MonitorViewModel.DeviceFirmware}" FontSize="9" Foreground="#E2E8F0" FontFamily="{StaticResource MonoFont}"/>
                    </Grid>
                </Border>

                <!-- GPC Info -->
                <Border Background="#0D1017" CornerRadius="8" Padding="10,8" Margin="0,0,0,10" BorderBrush="{StaticResource Border1}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="GPC" FontSize="9" Foreground="#64748B" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" FontSize="9" Foreground="#E2E8F0" FontFamily="{StaticResource MonoFont}">
                            <Run Text="{Binding MonitorViewModel.GpcName, Mode=OneWay}"/>
                            <Run Text=" v"/>
                            <Run Text="{Binding MonitorViewModel.GpcVersion, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Author" FontSize="9" Foreground="#64748B" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MonitorViewModel.GpcAuthor}" FontSize="9" Foreground="#E2E8F0" FontFamily="{StaticResource MonoFont}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Slot" FontSize="9" Foreground="#64748B" Margin="0,0,8,0"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding MonitorViewModel.ActiveSlot}" FontSize="9" Foreground="#E2E8F0" FontFamily="{StaticResource MonoFont}" Margin="0,0,8,0"/>
                            <TextBlock FontSize="9" FontFamily="{StaticResource MonoFont}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="NOT SENT"/>
                                        <Setter Property="Foreground" Value="{StaticResource ColorRed}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MonitorViewModel.GpcUploaded}" Value="True">
                                                <Setter Property="Text" Value="UPLOADED"/>
                                                <Setter Property="Foreground" Value="{StaticResource ColorGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Controller Buttons -->
                <WrapPanel>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnA, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="A" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnB, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="B" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnX, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="X" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnY, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Y" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnLB, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="LB" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnRB, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="RB" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnL3, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="L3" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnR3, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="R3" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnUp, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Up" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnDown, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Dn" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnLeft, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Lt" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnRight, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Rt" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnView, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Vw" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnMenu, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Mn" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,3" Margin="1" Background="{Binding MonitorViewModel.BtnXbox, Converter={StaticResource BtnColor}}">
                        <TextBlock Text="Xb" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
