<UserControl x:Class="Core_Aim.Pages.VisionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Core_Aim.Controls"
             xmlns:loc="clr-namespace:Core_Aim.Services"
             xmlns:converters="clr-namespace:Core_Aim.Converters">
    <UserControl.Resources>
        <converters:AppStatusConverter x:Key="StatusConverter"/>
        <converters:AppColorConverter x:Key="ColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="16,14,14,14">
        <CheckBox IsChecked="{Binding IsVISPinned, Mode=TwoWay}" HorizontalAlignment="Right" Margin="0,0,0,4" Cursor="Hand" Style="{StaticResource PinCheck}" />
        <TextBlock Text="{loc:Loc Vision}" Style="{StaticResource SectionTitle}" />

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="▸ MODELO" Style="{StaticResource SubsectionLabel}" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc Model}" Style="{StaticResource PLabel}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="&#x21BA;" Style="{StaticResource BtnSmall}" Command="{Binding SettingsViewModel.RefreshModelsCommand}" Width="24" Padding="0" />
                </Grid>
                <ComboBox ItemsSource="{Binding SettingsViewModel.Settings.ModelList}" SelectedItem="{Binding SettingsViewModel.SelectedModel}" Margin="0,0,0,10" />
                <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc Confidence}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.Settings.ConfidenceThreshold, StringFormat=P0}" Style="{StaticResource PValue}" /></Grid>
                <ctrl:NumericSlider Minimum="0.01" Maximum="1.0" SmallChange="0.01" LargeChange="0.1" Value="{Binding SettingsViewModel.Settings.ConfidenceThreshold, Mode=TwoWay}" Tint="#FF00F0FF" Margin="0,0,0,10" />
                <TextBlock Text="▸ FILTRO DE COR" Style="{StaticResource SubsectionLabel}" Margin="0,4,0,6" />
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc ColorFilter}" Style="{StaticResource PLabel}" VerticalAlignment="Center" />
                    <CheckBox Grid.Column="1" IsChecked="{Binding SettingsViewModel.ColorFilterEnabled}" />
                </Grid>
                <StackPanel Visibility="{Binding SettingsViewModel.ColorFilterEnabled, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding SettingsViewModel.ColorSlots[0]}" Command="{Binding SettingsViewModel.PickColorCommand}" CommandParameter="0" />
                        <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding SettingsViewModel.ColorSlots[1]}" Command="{Binding SettingsViewModel.PickColorCommand}" CommandParameter="1" />
                        <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding SettingsViewModel.ColorSlots[2]}" Command="{Binding SettingsViewModel.PickColorCommand}" CommandParameter="2" />
                        <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding SettingsViewModel.ColorSlots[3]}" Command="{Binding SettingsViewModel.PickColorCommand}" CommandParameter="3" />
                        <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding SettingsViewModel.ColorSlots[4]}" Command="{Binding SettingsViewModel.PickColorCommand}" CommandParameter="4" />
                    </StackPanel>
                    <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc ColorTolerance}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.ColorTolerance}" Style="{StaticResource PValueA}" /></Grid>
                    <ctrl:NumericSlider Minimum="0" Maximum="90" SmallChange="1" LargeChange="5" Value="{Binding SettingsViewModel.ColorTolerance, Mode=TwoWay}" Tint="#FFFFE000" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Save Images -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="▸ SALVAR IMAGENS" Style="{StaticResource SubsectionLabel}" />
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc AutoSaveLbl}" Style="{StaticResource PLabel}" VerticalAlignment="Center" />
                    <CheckBox Grid.Column="1" IsChecked="{Binding SettingsViewModel.SaveDetections}" Foreground="{StaticResource ColorGreen}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                </Grid>
                <CheckBox Content="{loc:Loc SaveEnemyOnly}" IsChecked="{Binding SettingsViewModel.SaveEnemyOnly, Mode=TwoWay}" IsEnabled="{Binding SettingsViewModel.SaveDetections}" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,3"><TextBlock Text="{loc:Loc CropSize}" Style="{StaticResource PLabel}" /><TextBlock Text="{Binding SettingsViewModel.Settings.DatasetCropSize, StringFormat=N0}" Style="{StaticResource PValueO}" /></Grid>
                <ctrl:NumericSlider Minimum="64" Maximum="640" SmallChange="32" LargeChange="64" Value="{Binding SettingsViewModel.Settings.DatasetCropSize, Mode=TwoWay}" Tint="#FFFF8800" />

                <!-- Label saving -->
                <TextBlock Text="▸ LABELS" Style="{StaticResource SubsectionLabel}" Margin="0,10,0,0" />
                <CheckBox Content="Save Labels (.txt)" IsChecked="{Binding SettingsViewModel.SaveLabels}" IsEnabled="{Binding SettingsViewModel.SaveDetections}" Foreground="#FF00FF9D" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                <CheckBox Content="YOLO Detections" IsChecked="{Binding SettingsViewModel.SaveLabelYolo}" IsEnabled="{Binding SettingsViewModel.SaveLabels}" Foreground="#FF00F0FF" FontSize="10" Margin="14,0,0,3" />
                <CheckBox Content="PixelBot Detections (class 0)" IsChecked="{Binding SettingsViewModel.SaveLabelPixelBot}" IsEnabled="{Binding SettingsViewModel.SaveLabels}" Foreground="#FFB400FF" FontSize="10" Margin="14,0,0,6" />

                <!-- Blur filter -->
                <TextBlock Text="▸ QUALITY FILTER" Style="{StaticResource SubsectionLabel}" Margin="0,6,0,0" />
                <CheckBox Content="Skip Blurry Images" IsChecked="{Binding SettingsViewModel.SkipBlurryImages}" IsEnabled="{Binding SettingsViewModel.SaveDetections}" Foreground="#FFFFE000" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,3" IsEnabled="{Binding SettingsViewModel.SkipBlurryImages}">
                    <TextBlock Text="Blur Threshold" Style="{StaticResource PLabel}" />
                    <TextBlock Text="{Binding SettingsViewModel.BlurThreshold, StringFormat=F0}" Style="{StaticResource PValueO}" />
                </Grid>
                <ctrl:NumericSlider Minimum="30" Maximum="300" SmallChange="10" LargeChange="50" Value="{Binding SettingsViewModel.Settings.BlurThreshold, Mode=TwoWay}" Tint="#FFFFE000" IsEnabled="{Binding SettingsViewModel.SkipBlurryImages}" />
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
