<UserControl x:Class="Core_Aim.Pages.CapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Core_Aim.Controls"
             xmlns:loc="clr-namespace:Core_Aim.Services"
             xmlns:converters="clr-namespace:Core_Aim.Converters">
    <UserControl.Resources>
        <converters:AppStatusConverter x:Key="StatusConverter"/>
        <converters:AppColorConverter x:Key="ColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="16,14,14,14">
        <CheckBox IsChecked="{Binding IsCAPPinned, Mode=TwoWay}" HorizontalAlignment="Right" Margin="0,0,0,4" Cursor="Hand" Style="{StaticResource PinCheck}" />
        <TextBlock Text="{loc:Loc Capture}" Style="{StaticResource SectionTitle}" />

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="▸ FONTE DE CAPTURA" Style="{StaticResource SubsectionLabel}" />
                <!-- Source toggle -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Background="{StaticResource BgInput}" CornerRadius="8" Padding="6,5" Margin="0,0,4,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SettingsViewModel.IsCameraMode}" Value="True"><Setter Property="BorderBrush" Value="{StaticResource Accent}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding SettingsViewModel.IsCameraMode}" Value="False"><Setter Property="BorderBrush" Value="{StaticResource Border1}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <RadioButton Content="Camera / Card" IsChecked="{Binding SettingsViewModel.IsCameraMode}" FontSize="10.5" GroupName="CapSrc3" HorizontalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource BgInput}" CornerRadius="8" Padding="6,5" Margin="4,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SettingsViewModel.IsScreenMode}" Value="True"><Setter Property="BorderBrush" Value="{StaticResource Accent}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding SettingsViewModel.IsScreenMode}" Value="False"><Setter Property="BorderBrush" Value="{StaticResource Border1}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <RadioButton Content="Screen Capture" IsChecked="{Binding SettingsViewModel.IsScreenMode}" FontSize="10.5" GroupName="CapSrc3" HorizontalAlignment="Center" />
                    </Border>
                </Grid>
                <!-- Camera mode -->
                <StackPanel Visibility="{Binding SettingsViewModel.IsCameraMode, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc VideoCaptureDevice}" Style="{StaticResource PLabel}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="{loc:Loc DetectDevices}" Style="{StaticResource BtnSmall}"
                                Command="{Binding SettingsViewModel.RefreshCamerasCommand}" Padding="8,2"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding SettingsViewModel.Settings.CameraList}"
                              SelectedIndex="{Binding SettingsViewModel.Settings.SelectedCameraIndex}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="{loc:Loc VideoInputConfig}" Style="{StaticResource PLabel}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource BgInput}" BorderBrush="{StaticResource Border1}" BorderThickness="1"
                                CornerRadius="8" Padding="4,5" Margin="0,0,4,0">
                            <TextBlock Text="{Binding SettingsViewModel.Settings.SelectedCameraIndex}"
                                       Foreground="{StaticResource TxtPri}" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding SettingsViewModel.CaptureBackendOptions}"
                                  SelectedIndex="{Binding SettingsViewModel.SelectedCaptureBackend}"/>
                    </Grid>

                    <TextBlock Text="{loc:Loc FrameResolution}" Style="{StaticResource PLabel}" Margin="0,0,0,4"/>
                    <Border Background="{StaticResource BgInput}" BorderBrush="{StaticResource Border1}" BorderThickness="1"
                            CornerRadius="8" Padding="8,6" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SettingsViewModel.CaptureWidth, Mode=OneWay}" Foreground="{StaticResource TxtPri}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text=" x " Foreground="{StaticResource TxtSec}" FontSize="12"/>
                            <TextBlock Text="{Binding SettingsViewModel.CaptureHeight, Mode=OneWay}" Foreground="{StaticResource TxtPri}" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <WrapPanel Margin="0,0,0,12">
                        <Button Content="640x480"   Tag="640,480"   Click="CapturePreset_Click" Style="{StaticResource BtnSmall}" Margin="0,0,4,4" Padding="6,3"/>
                        <Button Content="1280x720"  Tag="1280,720"  Click="CapturePreset_Click" Style="{StaticResource BtnSmall}" Margin="0,0,4,4" Padding="6,3"/>
                        <Button Content="1920x1080" Tag="1920,1080" Click="CapturePreset_Click" Style="{StaticResource BtnSmall}" Margin="0,0,4,4" Padding="6,3"/>
                        <Button Content="2560x1440" Tag="2560,1440" Click="CapturePreset_Click" Style="{StaticResource BtnSmall}" Margin="0,0,4,4" Padding="6,3"/>
                        <Button Content="3840x2160" Tag="3840,2160" Click="CapturePreset_Click" Style="{StaticResource BtnSmall}" Margin="0,0,0,4" Padding="6,3"/>
                    </WrapPanel>

                    <TextBlock Text="{loc:Loc AdvancedConfig}" Style="{StaticResource PLabel}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SettingsViewModel.CaptureAdvancedConfig, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" MinHeight="50" MaxHeight="80"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource BgInput}" Foreground="{StaticResource TxtPri}"
                             BorderBrush="{StaticResource Border1}" BorderThickness="1"
                             FontFamily="{StaticResource MonoFont}" FontSize="11" Padding="8,6"/>

                    <!-- Preview -->
                    <Grid Margin="0,12,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc PreviewLbl}" Style="{StaticResource PLabel}" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding SettingsViewModel.IsPreviewEnabled, Mode=TwoWay}" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc PreviewFpsLbl}" Style="{StaticResource PLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" Width="80" SelectedIndex="{Binding SettingsViewModel.PreviewFpsIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="30 fps" />
                            <ComboBoxItem Content="60 fps" />
                            <ComboBoxItem Content="120 fps" />
                            <ComboBoxItem Content="240 fps" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
                <!-- Screen mode -->
                <StackPanel Visibility="{Binding SettingsViewModel.IsScreenMode, Converter={StaticResource BoolToVis}}">
                    <Border Background="#0D1017" CornerRadius="8" Padding="10,8" BorderBrush="{StaticResource Border1}" BorderThickness="1">
                        <TextBlock Text="{loc:Loc ScreenCaptureInfo}" FontSize="10" Foreground="{StaticResource Accent}" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
