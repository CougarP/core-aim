<Window x:Class="Core_Aim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Core_Aim.ViewModels"
        xmlns:converters="clr-namespace:Core_Aim.Converters"
        xmlns:ctrl="clr-namespace:Core_Aim.Controls"
        xmlns:pages="clr-namespace:Core_Aim.Pages"
        xmlns:loc="clr-namespace:Core_Aim.Services"
        xmlns:services="clr-namespace:Core_Aim.Services"
        mc:Ignorable="d"
        Title="Core Aim Pro"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#FF010308"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>


    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- MAIN LAYOUT                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleRowDef"   Height="36" />
            <RowDefinition x:Name="ControlRowDef" Height="0" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="ConsoleRowDef" Height="0" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 0 — TITLE BAR (Phantom)            -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="#CC03070F" MouseDown="TitleBar_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Bottom electric line + scanline -->
            <Rectangle Height="1" VerticalAlignment="Bottom" Fill="{StaticResource TitleAccentBrush}" />

            <!-- LEFT: Hex logo + glitch wordmark -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <!-- Hex logo with CA monogram -->
                <Grid Width="24" Height="24" Margin="0,0,12,0">
                    <Path Data="M 12,1 L 22,6 L 22,18 L 12,23 L 2,18 L 2,6 Z"
                          Stroke="#FF00F0FF" StrokeThickness="1" Fill="#FF03070F">
                        <Path.Effect>
                            <DropShadowEffect Color="#FF00F0FF" BlurRadius="6" ShadowDepth="0" Opacity="0.8" />
                        </Path.Effect>
                    </Path>
                    <TextBlock Text="CA" FontFamily="{StaticResource DisplayFont}" FontSize="9" FontWeight="Bold"
                               Foreground="#FF00F0FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <!-- Wordmark — gradient Electric→Plasma per spec demo video -->
                <TextBlock Text="CORE_AIM" FontFamily="{StaticResource DisplayFont}" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFD8EEF8" Offset="0"/>
                            <GradientStop Color="#FF00F0FF" Offset="0.55"/>
                            <GradientStop Color="#FFB400FF" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF00F0FF" BlurRadius="6" ShadowDepth="0" Opacity="0.6" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="_PRO" FontFamily="{StaticResource DisplayFont}" FontSize="13" FontWeight="Bold"
                           Foreground="#FFB400FF" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FFB400FF" BlurRadius="6" ShadowDepth="0" Opacity="0.8" />
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Version chip -->
                <Border BorderBrush="#FF00F0FF" BorderThickness="1" Background="#1F00F0FF"
                        Padding="6,1" Margin="12,0,0,0" VerticalAlignment="Center" CornerRadius="0">
                    <TextBlock Text="V2.0" FontFamily="{StaticResource MonoFont}" FontSize="9"
                               Foreground="#FF00F0FF" />
                </Border>

                <!-- Subtitle telemetry -->
                <TextBlock Text="// ASSISTIVE TARGETING SYSTEM" FontFamily="{StaticResource MonoFont}" FontSize="9"
                           Foreground="#FF506070" VerticalAlignment="Center" Margin="14,0,0,0" />
            </StackPanel>

            <!-- RIGHT: Controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                <!-- Status badge -->
                <Border Background="#FF03070F" BorderBrush="#3300F0FF" BorderThickness="1"
                        Padding="10,3" Margin="0,0,12,0" VerticalAlignment="Center" CornerRadius="0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{Binding SystemStatusColor}" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FF00F0FF" BlurRadius="6" ShadowDepth="0" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="{Binding SystemStatus}" FontFamily="{StaticResource MonoFont}" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TxtPri}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <!-- START -->
                <Button Content="&#x25B6;  START" Command="{Binding StartSystemCommand}" Style="{StaticResource BtnStart}" Margin="0,0,6,0" />
                <!-- STOP -->
                <Button Content="&#x23F9;  STOP"  Command="{Binding StopSystemCommand}"  Style="{StaticResource BtnStop}" Margin="0,0,12,0" />

                <Border Width="1" Height="16" Background="#3300F0FF" Margin="0,0,6,0" VerticalAlignment="Center" />
                <!-- Console -->
                <Button x:Name="BtnConsole" Content="&#x2261;" FontSize="14" Style="{StaticResource WinBtn}" Click="ToggleConsole_Click" ToolTip="Output Log" Margin="0,0,2,0" />
                <!-- Fullscreen -->
                <Button x:Name="BtnEnterFullscreen" Content="&#x26F6;" FontSize="13" Style="{StaticResource WinBtn}" Click="BtnEnterFullscreen_Click" ToolTip="Fullscreen" Margin="0,0,2,0" />

                <Border Width="1" Height="16" Background="#3300F0FF" Margin="4,0" VerticalAlignment="Center" />
                <!-- Window controls -->
                <Button Content="&#x2500;" FontSize="12" Style="{StaticResource WinBtn}" Click="Minimize_Click" Margin="0,0,2,0" />
                <Button Content="&#x25A1;" FontSize="10" Style="{StaticResource WinBtn}" Click="Maximize_Click" Margin="0,0,2,0" />
                <Button Content="&#x2715;" FontSize="11" FontWeight="Bold" Style="{StaticResource WinBtnClose}" Click="Close_Click" />
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 1 — CONTROL BAR (hidden, shown in normal mode via toggle) -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Border Background="{StaticResource AbyssBrush}" CornerRadius="8" Padding="10,4" Margin="0,0,8,0"
                        BorderBrush="{StaticResource Border1}" BorderThickness="1">
                    <TextBlock Text="{Binding PerformanceMetricsInline}" FontSize="10"
                               Foreground="{StaticResource TxtSec}" VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 2 — MAIN CONTENT AREA              -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <!-- ┌─────────────────────────────────────────────────┐ -->
            <!-- │  PHANTOM 7-LAYER BACKGROUND STACK               │ -->
            <!-- │  (sits behind camera + sidebar; non-interactive) │ -->
            <!-- └─────────────────────────────────────────────────┘ -->
            <Grid IsHitTestVisible="False" Panel.ZIndex="-10">
                <!-- BitmapCache: rasteriza blur+orbs uma vez — sem recálculo por frame -->
                <Grid.CacheMode><BitmapCache/></Grid.CacheMode>
                <!-- L1: void base -->
                <Rectangle Fill="{StaticResource VoidBrush}" />
                <!-- L2: hex grid -->
                <Rectangle Fill="{StaticResource HexGridBrush}" Opacity="0.50" />
                <!-- L3a: top-left electric orb -->
                <Ellipse Width="700" Height="700"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-220,-260,0,0"
                         Fill="{StaticResource ElectricOrbBrush}"
                         Opacity="0.30">
                    <Ellipse.Effect>
                        <BlurEffect Radius="80" />
                    </Ellipse.Effect>
                </Ellipse>
                <!-- L3b: bottom-right plasma orb -->
                <Ellipse Width="640" Height="640"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-200,-220"
                         Fill="{StaticResource PlasmaOrbBrush}"
                         Opacity="0.22">
                    <Ellipse.Effect>
                        <BlurEffect Radius="80" />
                    </Ellipse.Effect>
                </Ellipse>
                <!-- L4: vignette -->
                <Rectangle Fill="{StaticResource VignetteBrush}" />
                <!-- L5: scanline overlay (subtle horizontal stripes) -->
                <Rectangle Opacity="0.04">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute" Stretch="None">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#FF00F0FF">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,4,1" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>

            <!-- CAMERA FEED — fills entire background -->
            <Grid x:Name="MainGrid" Background="Transparent"
                  MouseLeftButtonDown="CameraGrid_MouseLeftButtonDown">

                <!-- IdlePreview animated background — visible only when CameraFeed is null (spec §11) -->
                <ctrl:IdlePreview IsHitTestVisible="False">
                    <ctrl:IdlePreview.Style>
                        <Style TargetType="ctrl:IdlePreview">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MonitorViewModel.CameraFeed}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ctrl:IdlePreview.Style>
                </ctrl:IdlePreview>

                <Image Source="{Binding MonitorViewModel.CameraFeed}"
                       Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" />

                <!-- No-signal overlay — Phantom hex emblem + glitch text -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MonitorViewModel.CameraFeed}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <!-- Hex emblem -->
                    <Grid Width="96" Height="96" Margin="0,0,0,18">
                        <Path Data="M 48,4 L 88,24 L 88,72 L 48,92 L 8,72 L 8,24 Z"
                              Stroke="#FF00F0FF" StrokeThickness="1.5" Fill="#FF03070F">
                            <Path.Effect>
                                <DropShadowEffect Color="#FF00F0FF" BlurRadius="20" ShadowDepth="0" Opacity="0.8" />
                            </Path.Effect>
                        </Path>
                        <TextBlock Text="&#x25B6;" FontSize="34" Foreground="#FF00F0FF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </Grid>
                    <TextBlock Text="// NO SIGNAL"
                               FontFamily="{StaticResource DisplayFont}" FontSize="22" FontWeight="Bold"
                               Foreground="#FFD8EEF8" HorizontalAlignment="Center" />
                    <TextBlock Text="{loc:Loc PressStart}"
                               FontFamily="{StaticResource MonoFont}" FontSize="10"
                               Foreground="#FF506070" HorizontalAlignment="Center" Margin="0,8,0,0" />

                    <!-- Corner brackets around the emblem -->
                </StackPanel>

                <!-- HUD: Draggable metrics bar — Phantom HUD style -->
                <Canvas x:Name="MetricsCanvas">
                    <Border x:Name="MetricsBar"
                            Canvas.Left="650" Canvas.Top="20"
                            Cursor="SizeAll"
                            MouseLeftButtonDown="MetricsBar_DragStart"
                            MouseLeftButtonUp="MetricsBar_DragEnd"
                            MouseMove="MetricsBar_DragMove"
                            Background="#E603070F" CornerRadius="0" Padding="14,7"
                            BorderBrush="#8000F0FF" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF00F0FF" BlurRadius="14" ShadowDepth="0" Opacity="0.55" />
                        </Border.Effect>
                        <Border.Visibility>
                            <Binding Path="SettingsViewModel.ShowMetrics" Converter="{StaticResource BoolToVis}" />
                        </Border.Visibility>
                        <StackPanel Orientation="Horizontal">
                            <Border BorderBrush="#FF00FF9D" BorderThickness="1" Background="#1F00FF9D"
                                    Padding="6,2" Margin="0,0,10,0" CornerRadius="0">
                                <TextBlock Text="&#x25CF; LIVE" FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold"
                                           Foreground="#FF00FF9D" IsHitTestVisible="False" />
                            </Border>
                            <TextBlock Text="CAP " FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text="{Binding MonitorViewModel.NativeFps}" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Bold" Foreground="#FFD8EEF8" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text="{Binding MonitorViewModel.CaptureFps, StringFormat=/{0}}" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text=" fps" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False" />
                            <Border Width="1" Height="12" Background="#3300F0FF" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False" />
                            <TextBlock Text="AI " FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text="{Binding MonitorViewModel.InferenceFps}" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Bold" Foreground="#FF80E8FF" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text=" fps  " FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text="{Binding MonitorViewModel.InferenceMs, StringFormat={}{0:F1}}" FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Foreground="#FF80E8FF" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text=" ms" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False" />
                            <Border Width="1" Height="12" Background="#3300F0FF" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False" />
                            <TextBlock Text="PB " FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text="{Binding MonitorViewModel.PbFps}" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Bold" Foreground="#FFFFE000" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text=" fps" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False" />
                            <Border Width="1" Height="12" Background="#3300F0FF" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False" />
                            <TextBlock Text="TGT " FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="#FF506070" VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBlock Text="{Binding MonitorViewModel.DetectionCount}" FontFamily="{StaticResource MonoFont}" FontSize="14" FontWeight="Bold" Foreground="#FF00F0FF" VerticalAlignment="Center" IsHitTestVisible="False" />
                        </StackPanel>
                    </Border>
                </Canvas>

                <!-- HUD: Preview toggle (bottom-right) — Phantom -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,10,10" Background="#E603070F" CornerRadius="0" Padding="10,5"
                        BorderBrush="#8000F0FF" BorderThickness="1"
                        IsHitTestVisible="True" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SettingsViewModel.TogglePreviewCommand}" />
                    </Border.InputBindings>
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="&#x25CF; PRV ON" />
                                <Setter Property="Foreground" Value="{StaticResource ColorGreen}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SettingsViewModel.IsPreviewEnabled}" Value="False">
                                        <Setter Property="Text"       Value="&#x25CB; PRV OFF" />
                                        <Setter Property="Foreground" Value="{StaticResource TxtSec}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- HUD: Fullscreen hint — Phantom -->
                <Border x:Name="FullscreenHint" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,24" Background="#E603070F" CornerRadius="0" Padding="20,10"
                        BorderBrush="#8000F0FF" BorderThickness="1"
                        IsHitTestVisible="False">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF00F0FF" BlurRadius="14" ShadowDepth="0" Opacity="0.6" />
                    </Border.Effect>
                    <TextBlock x:Name="FullscreenHintText" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Bold" Foreground="#FFD8EEF8" />
                </Border>

                <!-- HUD: Fullscreen control bar — Phantom -->
                <Border x:Name="FsControlBar" Visibility="Collapsed"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,10,10,0" Background="#E603070F" CornerRadius="0" Padding="10,6"
                        BorderBrush="#8000F0FF" BorderThickness="1"
                        IsHitTestVisible="True">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="&#x25B6;  START" Command="{Binding StartSystemCommand}" Style="{StaticResource BtnStart}" Margin="0,0,6,0" />
                        <Button Content="&#x23F9;  STOP"  Command="{Binding StopSystemCommand}"  Style="{StaticResource BtnStop}"  Margin="0,0,10,0" />
                        <Button Click="BtnExitFullscreen_Click" ToolTip="Exit fullscreen (Esc)"
                                Width="30" Height="30" Background="#FF03070F"
                                BorderBrush="#3300F0FF" BorderThickness="1" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bfs" Background="{TemplateBinding Background}" CornerRadius="0"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <TextBlock Text="&#x26F6;" FontSize="13" Foreground="#FF506070"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bfs" Property="Background" Value="#1A00F0FF" />
                                            <Setter TargetName="bfs" Property="BorderBrush" Value="#FF00F0FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="&#x2715;" Click="Close_Click" ToolTip="Close"
                                Width="30" Height="30" Background="#FF03070F" Margin="6,0,0,0"
                                BorderBrush="#33FF3000" BorderThickness="1" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bx" Background="{TemplateBinding Background}" CornerRadius="0"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <TextBlock Text="{TemplateBinding Content}" FontSize="11" FontWeight="Bold"
                                                   Foreground="#FFFF3000"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bx" Property="Background" Value="#33FF3000" />
                                            <Setter TargetName="bx" Property="BorderBrush" Value="#FFFF3000" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- (floating buttons removed — START/STOP only in title bar) -->
            </Grid>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- PHANTOM SHELL — Sidebar 38px + balões EMBEDDED fixos.    -->
            <!-- Cada balão tem Visibility ligada a IsXXVisible da VM.    -->
            <!-- Layout: StackPanel horizontal, balões aparecem ao lado    -->
            <!-- da sidebar à medida que o utilizador clica nos icones.   -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border x:Name="OverlayCanvas" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                <StackPanel Orientation="Horizontal">
                    <!-- 38px Phantom slim sidebar (binds to ToggleTabCommand) -->
                    <ctrl:PhantomSidebar />

                    <!-- Balões embedded — horizontal scroll quando muitos abertos.
                         Cada um é um PhantomBalloonHost com top line animada,
                         corner brackets (TL Electric / BR Plasma), entrance
                         animation 140ms e botão close. (spec phantom_balloons.txt §404-422) -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Margin="14,18,0,18">
                        <StackPanel Orientation="Horizontal">

                            <ctrl:PhantomBalloonHost Width="320" Title="// HARDWARE" TabCode="HW"
                                Visibility="{Binding IsHWVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:HardwarePage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// DETECTION" TabCode="DET"
                                Visibility="{Binding IsDETVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:DetectionPage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// TRACKING" TabCode="TRK"
                                Visibility="{Binding IsTRKVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:TrackingPage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// TRIGGER" TabCode="TRG"
                                Visibility="{Binding IsTRGVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:TriggerPage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// OVERLAY" TabCode="OVL"
                                Visibility="{Binding IsOVLVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:OverlayPage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// VISION" TabCode="VIS"
                                Visibility="{Binding IsVISVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:VisionPage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// CAPTURE" TabCode="CAP"
                                Visibility="{Binding IsCAPVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:CapturePage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// MONITOR" TabCode="MON"
                                Visibility="{Binding IsMONVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:MonitorPage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                            <ctrl:PhantomBalloonHost Width="320" Title="// USER" TabCode="USR"
                                Visibility="{Binding IsUSRVisible, Converter={StaticResource BoolToVis}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="720">
                                    <pages:UserPage/>
                                </ScrollViewer>
                            </ctrl:PhantomBalloonHost>

                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 3 — OUTPUT LOG CONSOLE — Phantom   -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#FF010308" BorderBrush="#3300F0FF" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Console header bar -->
                <Grid Grid.Row="0" Background="#CC03070F">
                    <Rectangle Height="1" VerticalAlignment="Bottom" Fill="{StaticResource TitleAccentBrush}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <Rectangle Width="3" Height="14" Fill="#FF00F0FF">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="#FF00F0FF" BlurRadius="6" ShadowDepth="0" />
                            </Rectangle.Effect>
                        </Rectangle>
                        <TextBlock Text="// OUTPUT LOG" FontFamily="{StaticResource MonoFont}" FontSize="10" FontWeight="Bold"
                                   Foreground="#FF00F0FF" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBlock Text="{Binding ConsoleLines.Count, StringFormat='[ {0} entries ]'}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="#FF506070" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button Content="&#x2398;" ToolTip="Copy" Click="CopyConsole_Click" Style="{StaticResource WinBtn}" FontSize="11" Width="28" />
                        <Button Content="&#x2715;" ToolTip="Close" Click="ToggleConsole_Click" Style="{StaticResource WinBtnClose}" FontSize="10" Width="28" />
                    </StackPanel>
                </Grid>
                <ListBox x:Name="ConsoleList" Grid.Row="1"
                         ItemsSource="{Binding ConsoleLines}"
                         Background="#FF010308" BorderThickness="0"
                         FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="#FF8AAABB"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="14,2" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#1F00F0FF" /></Trigger>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1A00F0FF" /></Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="NoWrap" FontFamily="{StaticResource MonoFont}" FontSize="10" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- STUDIO MODE OVERLAY (Training — full window) -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.RowSpan="4" Background="#FF010308" Panel.ZIndex="1500">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStudioMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <pages:TrainingPage/>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- FUZER MODE OVERLAY (full window)       -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.RowSpan="4" Background="Black" Panel.ZIndex="999">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFuzerMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Camera feed with detection overlays (same binding as main feed) -->
            <Image Source="{Binding MonitorViewModel.CameraFeed}"
                   Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality" />

            <!-- Exit button (top-right corner) -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,12,16,0" Width="36" Height="36" Cursor="Hand"
                    Command="{Binding ToggleFuzerCommand}"
                    Background="#40FFFFFF" Foreground="White" FontSize="16" FontWeight="Bold"
                    Content="&#x2715;">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="fb" Background="#40FFFFFF" CornerRadius="18" Width="36" Height="36">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="fb" Property="Background" Value="#80FF4444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

    </Grid>
</Window>
