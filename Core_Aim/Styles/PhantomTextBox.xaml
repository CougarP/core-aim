<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM TEXTBOX — spec §6
         Border-left 2px Electric, dark transparent bg, Consolas 11.
         IsFocused → BorderBrush full Electric + subtle inner glow.
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="PhantomTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
        <Setter Property="CaretBrush" Value="#FF00F0FF"/>
        <Setter Property="SelectionBrush" Value="#5500F0FF"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="Background" Value="#80000000"/>
        <Setter Property="BorderBrush" Value="#FF1E2E42"/>
        <Setter Property="BorderThickness" Value="2,1,1,1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#5500F0FF"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF00F0FF"/>
                            <Setter TargetName="Bd" Property="Background" Value="#90001020"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Numeric variant: monospace right-aligned for stat fields -->
    <Style x:Key="PhantomTextBoxNumeric" TargetType="TextBox" BasedOn="{StaticResource PhantomTextBox}">
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="Foreground" Value="#FF00F0FF"/>
    </Style>

</ResourceDictionary>
