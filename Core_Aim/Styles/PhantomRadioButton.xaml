<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM RADIO BUTTON — spec §5
         Container border + 9px ellipse dot.
         IsChecked → border #4700F0FF + bg #0D00F0FF + dot Electric fill.
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="PhantomRadio" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Container"
                            BorderBrush="#FF1E2E42"
                            BorderThickness="1"
                            Background="Transparent"
                            Padding="7,7">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="Dot"
                                     Width="9" Height="9"
                                     Stroke="#FF304050"
                                     StrokeThickness="2"
                                     Fill="Transparent"/>
                            <ContentPresenter Margin="7,0,0,0"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Container" Property="BorderBrush" Value="#3300F0FF"/>
                            <Setter TargetName="Dot" Property="Stroke" Value="#5500F0FF"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Container" Property="BorderBrush" Value="#4700F0FF"/>
                            <Setter TargetName="Container" Property="Background" Value="#0D00F0FF"/>
                            <Setter TargetName="Dot" Property="Stroke" Value="#FF00F0FF"/>
                            <Setter TargetName="Dot" Property="Fill" Value="#FF00F0FF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
