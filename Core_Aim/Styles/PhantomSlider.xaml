<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM SLIDER — spec §4
         Layout: [- 20px] [Track *] [+ 20px]
         Track: 2px height, decrease=ElectricPlasma gradient, increase=#0DFFFFFF
         Thumb: 10x10 Rectangle rotated 45° (diamante), Electric stroke + glow
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="PhantomSliderRepeatTransparent" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style x:Key="PhantomSliderThumb" TargetType="Thumb">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <!-- Cor lida do Foreground do Slider pai (TemplatedParent.Foreground via ancestor binding).
             Permite cada NumericSlider ter sua própria cor (Tint). -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Rectangle Width="10" Height="10"
                                   Fill="#FF010308"
                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"
                                   StrokeThickness="2"
                                   RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="45"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Track-only variant (no − / + buttons) — for use inside NumericSlider which has its own buttons.
         O Foreground do Slider passa a representar a TINT (cor do preenchimento + thumb).
         Default: Electric (#00F0FF). Slider pai pode sobrescrever para amarelo, verde, etc. -->
    <Style x:Key="PhantomSliderTrackOnly" TargetType="Slider">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="MinHeight" Value="18"/>
        <Setter Property="Foreground" Value="#FF00F0FF"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Track x:Name="PART_Track" Margin="0">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Style="{StaticResource PhantomSliderRepeatTransparent}"
                                          Command="Slider.DecreaseLarge">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Rectangle Height="2" VerticalAlignment="Center"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Style="{StaticResource PhantomSliderRepeatTransparent}"
                                          Command="Slider.IncreaseLarge">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Rectangle Height="2" VerticalAlignment="Center"
                                                   Fill="#0DFFFFFF"/>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Track.IncreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb Style="{StaticResource PhantomSliderThumb}"/>
                        </Track.Thumb>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default implicit Slider style — applies to ALL Sliders (incl. inside NumericSlider) -->
    <Style TargetType="Slider" BasedOn="{StaticResource PhantomSliderTrackOnly}"/>

    <Style x:Key="PhantomSlider" TargetType="Slider">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>

                        <!-- MINUS button -->
                        <Border Grid.Column="0" Height="20"
                                BorderBrush="#FF1E2E42"
                                BorderThickness="1"
                                Background="Transparent">
                            <TextBlock Text="—"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       Foreground="#FF304050"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- TRACK -->
                        <Track Grid.Column="1" x:Name="PART_Track" Margin="6,0">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource PhantomSliderRepeatTransparent}"
                                              Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Rectangle Height="2" VerticalAlignment="Center"
                                                       Fill="{StaticResource SliderFillElectric}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>

                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource PhantomSliderRepeatTransparent}"
                                              Command="Slider.IncreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Rectangle Height="2" VerticalAlignment="Center"
                                                       Fill="#0DFFFFFF"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>

                            <Track.Thumb>
                                <Thumb Style="{StaticResource PhantomSliderThumb}"/>
                            </Track.Thumb>
                        </Track>

                        <!-- PLUS button -->
                        <Border Grid.Column="2" Height="20"
                                BorderBrush="#FF1E2E42"
                                BorderThickness="1"
                                Background="Transparent">
                            <TextBlock Text="+"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       Foreground="#FF304050"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
