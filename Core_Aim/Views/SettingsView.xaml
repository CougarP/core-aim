<UserControl x:Class="Core_Aim.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Core_Aim.Converters"
             xmlns:sys="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             mc:Ignorable="d" 
             d:DesignHeight="1100" d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <converters:AppStatusConverter x:Key="StatusConverter"/>
        <converters:AppColorConverter x:Key="ColorConverter"/>
        <sys:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToButtonColorConverter x:Key="BtnColor"/>

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="#181A20"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,15,15"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="AutoToolTipPlacement" Value="TopLeft"/>
            <Setter Property="AutoToolTipPrecision" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="White" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
        <StackPanel>

            <TextBlock Text="Configuration Dashboard" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="⚡ Aim Mechanics (Speed)" Style="{StaticResource CardTitle}"/>
                            <Separator Background="#27272A" Margin="0,0,0,15"/>

                            <TextBlock Text="Speed Profile" Style="{StaticResource InputLabel}"/>
                            <ComboBox ItemsSource="{Binding SpeedProfiles}" SelectedItem="{Binding SelectedSpeedProfile}" Padding="8" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tracking Speed (HIP)" Style="{StaticResource InputLabel}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TrackingSpeedHIP, StringFormat=F2}" Foreground="#6366F1" FontWeight="Bold"/>
                            </Grid>
                            <Slider Minimum="0.1" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                    Value="{Binding TrackingSpeedHIP, Mode=TwoWay}" TickFrequency="0.1" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tracking Speed (ADS/Fire)" Style="{StaticResource InputLabel}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TrackingSpeedADS, StringFormat=F2}" Foreground="#6366F1" FontWeight="Bold"/>
                            </Grid>
                            <Slider Minimum="0.1" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                                    Value="{Binding TrackingSpeedADS, Mode=TwoWay}" TickFrequency="0.1" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Response Curve" Style="{StaticResource InputLabel}"/>
                                    <TextBlock Text="Lower = Linear / Higher = Exponential" FontSize="9" Foreground="#555"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding AimResponseCurve, StringFormat=F2}" Foreground="#6366F1" FontWeight="Bold"/>
                            </Grid>
                            <Slider Minimum="0.01" Maximum="0.50" SmallChange="0.01" LargeChange="0.1"
                                    Value="{Binding AimResponseCurve, Mode=TwoWay}" TickFrequency="0.1" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tracking Delay (ms)" Style="{StaticResource InputLabel}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TrackingDelay, StringFormat=N0}" Foreground="#F59E0B" FontWeight="Bold"/>
                            </Grid>
                            <Slider Minimum="0" Maximum="200" SmallChange="10" LargeChange="50"
                                    Value="{Binding TrackingDelay, Mode=TwoWay}" TickFrequency="10" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Restricted Tracking (%)" Style="{StaticResource InputLabel}"/>
                                <TextBlock Grid.Column="1" Text="{Binding RestrictedTracking, StringFormat=N0}" Foreground="#F59E0B" FontWeight="Bold"/>
                            </Grid>
                            <Slider Minimum="10" Maximum="100" SmallChange="5" LargeChange="10"
                                    Value="{Binding RestrictedTracking, Mode=TwoWay}" TickFrequency="10"/>
                            <TextBlock Text="Limits movement to a % of the max FOV" FontSize="10" Foreground="#555" Margin="0,2,0,5"/>

                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="🧠 Prediction &amp; Recoil" Style="{StaticResource CardTitle}"/>
                            <Separator Background="#27272A" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Enable Prediction" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding PredictionEnabled}" VerticalAlignment="Center">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </Grid>

                            <StackPanel Visibility="{Binding PredictionEnabled, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15">
                                <TextBlock Text="Algorithm" Style="{StaticResource InputLabel}"/>
                                <ComboBox ItemsSource="{Binding PredictionMethods}" SelectedItem="{Binding SelectedPredictionMethod}" Padding="6"/>
                            </StackPanel>

                            <Separator Background="#27272A" Margin="0,5,0,15"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Enable Anti-Recoil" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding RecoilEnabled}" VerticalAlignment="Center">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </Grid>

                            <StackPanel Visibility="{Binding RecoilEnabled, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Vertical Force" Style="{StaticResource InputLabel}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RecoilVertical}" Foreground="#10B981" FontWeight="Bold"/>
                                </Grid>
                                <Slider Minimum="0" Maximum="100" Value="{Binding RecoilVertical, Mode=TwoWay}" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Horizontal Force" Style="{StaticResource InputLabel}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RecoilHorizontal}" Foreground="#10B981" FontWeight="Bold"/>
                                </Grid>
                                <Slider Minimum="-100" Maximum="100" Value="{Binding RecoilHorizontal, Mode=TwoWay}" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Interval (ms)" Style="{StaticResource InputLabel}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RecoilInterval}" Foreground="#555" FontWeight="Bold"/>
                                </Grid>
                                <Slider Minimum="10" Maximum="200" Value="{Binding RecoilInterval, Mode=TwoWay}"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="🎯 Target Offset" Style="{StaticResource CardTitle}"/>
                            <Separator Background="#27272A" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Content="YOLO (Body)"
                                             IsChecked="{Binding IsPlayerMode, Mode=TwoWay}"
                                             Foreground="#10B981" FontSize="11" FontWeight="Bold" GroupName="TargetMode"/>
                                <RadioButton Grid.Column="1" Content="PixelBot (Icon)"
                                             IsChecked="{Binding IsIconMode, Mode=TwoWay}"
                                             Foreground="#F59E0B" FontSize="11" FontWeight="Bold" GroupName="TargetMode"/>
                            </Grid>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Offset" Style="{StaticResource InputLabel}"/>
                                <TextBlock Grid.Column="1" Text="{Binding AimOffsetY, StringFormat=N0}" FontWeight="Bold"/>
                            </Grid>
                            <Slider Value="{Binding AimOffsetY, Mode=TwoWay}"
                                    Minimum="0" Maximum="100"
                                    SmallChange="1" LargeChange="5"
                                    TickFrequency="10" />
                            <TextBlock Text="YOLO: inside box (0=feet, 100=head) — PB: below icon" FontSize="10" Foreground="#555" Margin="0,2,0,5"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <StackPanel Grid.Column="1">

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="🎮 Hardware Output" Style="{StaticResource CardTitle}" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Content="Titan Two" IsChecked="{Binding IsTitanSelected}" Foreground="White" GroupName="HwType"/>
                                <RadioButton Grid.Column="1" Content="KMBox Net" IsChecked="{Binding IsKmBoxSelected}" Foreground="White" GroupName="HwType"/>
                            </Grid>

                            <Separator Background="#27272A" Margin="0,0,0,15"/>

                            <StackPanel Visibility="{Binding IsTitanSelected, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Titan Connection" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                                    <Button Command="{Binding ToggleTitanConnectionCommand}"
                                            Content="{Binding IsTitanConnected, Converter={StaticResource StatusConverter}}"
                                            Background="{Binding IsTitanConnected, Converter={StaticResource ColorConverter}}"
                                            Padding="10,4" FontSize="10" BorderThickness="0" Foreground="White" Grid.Column="1"/>
                                </Grid>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Protocol" Style="{StaticResource InputLabel}"/>
                                        <ComboBox ItemsSource="{Binding ProtocolLabels}" SelectedItem="{Binding SelectedProtocol}" Padding="6"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Slot" Style="{StaticResource InputLabel}"/>
                                        <ComboBox ItemsSource="{Binding SlotNumbers}" SelectedItem="{Binding SelectedSlot}" Padding="6"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Macros GPC -->
                                <Separator Background="#27272A" Margin="0,15,0,10"/>
                                <TextBlock Text="Macros (CoD)" Foreground="#F59E0B" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <WrapPanel Margin="0,0,0,4">
                                    <CheckBox Content="Rapid Fire" IsChecked="{Binding MacroRapidFire}" Foreground="White" FontSize="10" Margin="0,0,12,4" VerticalContentAlignment="Center"/>
                                    <CheckBox Content="Anti-Recoil" IsChecked="{Binding MacroAntiRecoil}" Foreground="White" FontSize="10" Margin="0,0,12,4" VerticalContentAlignment="Center"/>
                                    <CheckBox Content="Drop Shot" IsChecked="{Binding MacroDropShot}" Foreground="White" FontSize="10" Margin="0,0,12,4" VerticalContentAlignment="Center"/>
                                    <CheckBox Content="Crouch Peek" IsChecked="{Binding MacroCrouchPeek}" Foreground="White" FontSize="10" Margin="0,0,12,4" VerticalContentAlignment="Center"/>
                                    <CheckBox Content="Tac Sprint" IsChecked="{Binding MacroTacSprint}" Foreground="White" FontSize="10" Margin="0,0,12,4" VerticalContentAlignment="Center"/>
                                    <CheckBox Content="Slide Cancel" IsChecked="{Binding MacroSlideCancel}" Foreground="White" FontSize="10" Margin="0,0,12,4" VerticalContentAlignment="Center"/>
                                    <CheckBox Content="Auto Ping" IsChecked="{Binding MacroAutoPing}" Foreground="White" FontSize="10" Margin="0,0,12,4" VerticalContentAlignment="Center"/>
                                </WrapPanel>

                                <!-- Controller State -->
                                <Separator Background="#27272A" Margin="0,15,0,10"/>
                                <TextBlock Text="Controller Input" Foreground="#A1A1AA" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <!-- Triggers: numeros 0-100% -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="LT " Foreground="#A1A1AA" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DataContext.MonitorViewModel.LTValue, RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0}%}"
                                                   Foreground="#6366F1" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="RT " Foreground="#A1A1AA" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DataContext.MonitorViewModel.RTValue, RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0}%}"
                                                   Foreground="#6366F1" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Sticks -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Left Stick" Foreground="#A1A1AA" FontSize="10"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DataContext.MonitorViewModel.StickLX, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=X:{0}}"
                                                       Foreground="White" FontSize="11" FontFamily="{StaticResource MonoFont}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding DataContext.MonitorViewModel.StickLY, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Y:{0}}"
                                                       Foreground="White" FontSize="11" FontFamily="{StaticResource MonoFont}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Right Stick" Foreground="#A1A1AA" FontSize="10"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DataContext.MonitorViewModel.StickRX, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=X:{0}}"
                                                       Foreground="White" FontSize="11" FontFamily="{StaticResource MonoFont}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding DataContext.MonitorViewModel.StickRY, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Y:{0}}"
                                                       Foreground="White" FontSize="11" FontFamily="{StaticResource MonoFont}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Buttons grid -->
                                <WrapPanel Margin="0,2,0,0">
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnA, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="A" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnB, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="B" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnX, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="X" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnY, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="Y" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnLB, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="LB" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnRB, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="RB" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnL3, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="L3" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnR3, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="R3" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnUp, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="Up" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnDown, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="Dn" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnLeft, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="Lt" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnRight, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="Rt" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="View" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,3" Margin="2" Background="{Binding DataContext.MonitorViewModel.BtnMenu, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnColor}}">
                                        <TextBlock Text="Menu" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsKmBoxSelected, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="KMBox Connection" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                                    <Button Command="{Binding ToggleKmBoxConnectionCommand}"
                                            Content="{Binding KmBoxStatusText}"
                                            Background="{Binding KmBoxStatusColor}"
                                            Padding="10,4" FontSize="10" BorderThickness="0" Foreground="White" Grid.Column="1"/>
                                </Grid>

                                <TextBlock Text="IP Address" Style="{StaticResource InputLabel}"/>
                                <TextBox Text="{Binding KmBoxIp}" Padding="5" Background="#202229" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Port" Style="{StaticResource InputLabel}"/>
                                        <TextBox Text="{Binding KmBoxPort}" Padding="5" Background="#202229" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="UUID (Hex)" Style="{StaticResource InputLabel}"/>
                                        <TextBox Text="{Binding KmBoxUuid}" Padding="5" Background="#202229" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="📷 Vision &amp; AI" Style="{StaticResource CardTitle}"/>
                            <Separator Background="#27272A" Margin="0,0,0,15"/>

                            <TextBlock Text="Select Model" Style="{StaticResource InputLabel}"/>
                            <ComboBox ItemsSource="{Binding Settings.ModelList}"
                                      SelectedItem="{Binding SelectedModel}"
                                      Padding="8" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FOV Size (Pixels)" Style="{StaticResource InputLabel}"/>
                                <CheckBox Content="Show Circle" IsChecked="{Binding ShowFov}" 
                                          Foreground="#6366F1" FontSize="10" FontWeight="Bold" 
                                          VerticalAlignment="Top" Grid.Column="1"/>
                            </Grid>
                            <Slider Value="{Binding FovSize, Mode=TwoWay}"
                                    Minimum="50" Maximum="800" 
                                    SmallChange="1" LargeChange="10"
                                    TickFrequency="50" Margin="0,0,0,15"/>

                            <TextBlock Text="Confidence Threshold" Style="{StaticResource InputLabel}"/>
                            <Grid Margin="0,0,0,5">
                                <TextBlock HorizontalAlignment="Right" Text="{Binding Settings.ConfidenceThreshold, StringFormat=P0}" Foreground="#6366F1" FontWeight="Bold"/>
                            </Grid>
                            <Slider Value="{Binding Settings.ConfidenceThreshold, Mode=TwoWay}"
                                    Minimum="0.01" Maximum="1.0" 
                                    SmallChange="0.01" LargeChange="0.1"
                                    TickFrequency="0.1" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="Show Boxes" IsChecked="{Binding Settings.ShowBoundingBoxes}" Foreground="#6366F1" FontSize="11" FontWeight="SemiBold"/>
                                <CheckBox Grid.Column="1" Content="💾 Auto-Save" IsChecked="{Binding SaveDetections}" Foreground="#10B981" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Opções de caixas — visível apenas quando Show Boxes ativo -->
                            <StackPanel Margin="0,0,0,10"
                                        IsEnabled="{Binding Settings.ShowBoundingBoxes}">

                                <!-- Estilo -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Estilo" Foreground="#9CA3AF" FontSize="10" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Width="130" FontSize="10"
                                              SelectedIndex="{Binding Settings.BoxStyle, Mode=TwoWay}">
                                        <ComboBoxItem Content="Quadrado"/>
                                        <ComboBoxItem Content="Apenas Cantos"/>
                                        <ComboBoxItem Content="Arredondado"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Espessura -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Espessura da Linha" Foreground="#9CA3AF" FontSize="10" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Width="60" FontSize="10"
                                              SelectedIndex="{Binding Settings.BoxThicknessIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="3"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Preenchimento -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="Preenchimento" Foreground="#9CA3AF" FontSize="10" VerticalAlignment="Center"
                                              IsChecked="{Binding Settings.BoxFillEnabled, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1" Foreground="#6366F1" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"
                                               Text="{Binding Settings.BoxFillAlpha}"
                                               Visibility="{Binding Settings.BoxFillEnabled, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                                <Slider Minimum="5" Maximum="200" SmallChange="5" LargeChange="20"
                                        Value="{Binding Settings.BoxFillAlpha, Mode=TwoWay}"
                                        Margin="0,0,0,4"
                                        IsEnabled="{Binding Settings.BoxFillEnabled}"
                                        Visibility="{Binding Settings.BoxFillEnabled, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <CheckBox Content="💾 Salvar apenas Enemy (ignorar Friend/Color)"
                                      IsChecked="{Binding SaveEnemyOnly}"
                                      Foreground="#F59E0B" FontSize="11" FontWeight="SemiBold"
                                      Margin="0,0,0,6"
                                      IsEnabled="{Binding SaveDetections}"/>

                            <Separator Background="#27272A" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎨 Color Filter" Style="{StaticResource InputLabel}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="(5 Colors)" Style="{StaticResource InputLabel}" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding ColorFilterEnabled}" VerticalAlignment="Center">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding ColorSlots[0]}" Command="{Binding PickColorCommand}" CommandParameter="0"/>
                                <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding ColorSlots[1]}" Command="{Binding PickColorCommand}" CommandParameter="1"/>
                                <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding ColorSlots[2]}" Command="{Binding PickColorCommand}" CommandParameter="2"/>
                                <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding ColorSlots[3]}" Command="{Binding PickColorCommand}" CommandParameter="3"/>
                                <Button Style="{StaticResource ColorButtonStyle}" Background="{Binding ColorSlots[4]}" Command="{Binding PickColorCommand}" CommandParameter="4"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Color Tolerance" Style="{StaticResource InputLabel}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ColorTolerance}" Foreground="#6366F1" FontWeight="Bold"/>
                            </Grid>
                            <Slider Value="{Binding ColorTolerance}" Minimum="0" Maximum="90" 
                                    SmallChange="1" LargeChange="5" 
                                    TickFrequency="10" Margin="0,0,0,15"/>

                            <Separator Background="#27272A" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Trigger" Style="{StaticResource InputLabel}"/>
                                    <ComboBox ItemsSource="{Binding TriggerLabels}" SelectedIndex="{Binding SelectedTrigger}" Padding="8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Mode" Style="{StaticResource InputLabel}"/>
                                    <ComboBox ItemsSource="{Binding InferenceModeLabels}" SelectedIndex="{Binding SelectedInferenceMode}" Padding="8"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📺 Input Source" Grid.Column="0" Style="{StaticResource CardTitle}" Margin="0" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding IsPreviewEnabled, Mode=TwoWay}" Content="Preview" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Content="Camera / Capture Card" IsChecked="{Binding IsCameraMode}" Foreground="White" GroupName="CaptureType" VerticalAlignment="Center"/>
                                <RadioButton Grid.Column="1" Content="Screen Capture" IsChecked="{Binding IsScreenMode}" Foreground="White" GroupName="CaptureType" VerticalAlignment="Center"/>
                            </Grid>

                            <Separator Background="#27272A" Margin="0,0,0,15"/>

                            <ComboBox ItemsSource="{Binding Settings.CameraList}" 
                                      SelectedIndex="{Binding Settings.SelectedCameraIndex}" 
                                      Visibility="{Binding IsCameraMode, Converter={StaticResource BoolToVis}}"
                                      Padding="6" Margin="0,0,0,10"/>

                            <Border CornerRadius="6" Background="Black" Height="180" ClipToBounds="True"
                                    Visibility="{Binding IsPreviewEnabled, Converter={StaticResource BoolToVis}}">
                                <Image Source="{Binding DataContext.MonitorViewModel.CameraFeed, RelativeSource={RelativeSource AncestorType=Window}}" Stretch="Uniform"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>