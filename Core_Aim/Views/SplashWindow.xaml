<Window x:Class="Core_Aim.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Core Aim" Width="520" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <!-- Totalmente transparente + IsHitTestVisible=False = cliques passam direto -->
    <Border CornerRadius="0" Background="Transparent"
            BorderThickness="0" IsHitTestVisible="False">

        <!-- Root grid — everything is centered here -->
        <Grid x:Name="RootGrid" Width="518" Height="518" ClipToBounds="True">

            <!-- Particles canvas (under logo) -->
            <Canvas x:Name="ParticlesCanvas" Width="518" Height="518"
                    HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Expanding ring 1 -->
            <Ellipse x:Name="Ring1"
                     Width="60" Height="60"
                     Stroke="#DC2626" StrokeThickness="1.5"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="Ring1Scale" ScaleX="1" ScaleY="1"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Expanding ring 2 -->
            <Ellipse x:Name="Ring2"
                     Width="60" Height="60"
                     Stroke="#991B1B" StrokeThickness="1"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="Ring2Scale" ScaleX="1" ScaleY="1"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Expanding ring 3 -->
            <Ellipse x:Name="Ring3"
                     Width="60" Height="60"
                     Stroke="#7F1D1D" StrokeThickness="0.5"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="Ring3Scale" ScaleX="1" ScaleY="1"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Logo group -->
            <StackPanel x:Name="LogoGroup"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5" Opacity="0">
                <StackPanel.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="0" ScaleY="0"/>
                </StackPanel.RenderTransform>

                <!-- Red accent bar -->
                <Rectangle Width="40" Height="3" Fill="#DC2626"
                           HorizontalAlignment="Center" Margin="0,0,0,14" RadiusX="1.5" RadiusY="1.5"/>

                <!-- Main logo text -->
                <TextBlock x:Name="LogoText"
                           Text="CORE AIM"
                           FontSize="52" FontWeight="Bold"
                           Foreground="White"
                           TextAlignment="Center"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#DC2626" Opacity="0.85"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Subtitle -->
                <TextBlock x:Name="SubText"
                           Text="P R E C I S I O N   T A R G E T I N G"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#DC2626"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Opacity="0"/>
            </StackPanel>

            <!-- Full-screen fade overlay (used for explosion white flash) -->
            <Rectangle x:Name="FlashOverlay"
                       Fill="White" Opacity="0"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        </Grid>
    </Border>
</Window>
