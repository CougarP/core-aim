<Window x:Class="Core_Aim.Views.Splash.SplashHoloWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Core Aim" Width="640" Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Border IsHitTestVisible="False" CornerRadius="0">
        <Grid x:Name="Root" ClipToBounds="True">

            <!-- L1: void background -->
            <Rectangle Fill="{StaticResource VoidBrush}"/>

            <!-- L2: vignette -->
            <Rectangle Fill="{StaticResource VignetteBrush}"/>

            <!-- L3: scanned-in hex grid (random fade-in handled in code) -->
            <Rectangle x:Name="HexLayer"
                       Fill="{StaticResource HexGridBrushDense}"
                       Opacity="0"/>

            <!-- L4: corner brackets (drawn in via stroke dash anim) -->
            <Path x:Name="BrkTL" Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                  Data="M 0,40 L 0,0 L 40,0"
                  Margin="32,32,0,0"
                  HorizontalAlignment="Left" VerticalAlignment="Top"
                  Opacity="0"/>
            <Path x:Name="BrkTR" Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                  Data="M 0,0 L 40,0 L 40,40"
                  Margin="0,32,32,0"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Opacity="0"/>
            <Path x:Name="BrkBL" Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                  Data="M 0,0 L 0,40 L 40,40"
                  Margin="32,0,0,32"
                  HorizontalAlignment="Left" VerticalAlignment="Bottom"
                  Opacity="0"/>
            <Path x:Name="BrkBR" Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                  Data="M 0,40 L 40,40 L 40,0"
                  Margin="0,0,32,32"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  Opacity="0"/>

            <!-- L5: corner HUD telemetry -->
            <TextBlock x:Name="HudTL" Text="SYS://CORE_AIM_PRO"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       Margin="78,38,0,0"
                       Foreground="{StaticResource ElectricBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Opacity="0"/>
            <TextBlock x:Name="HudTR" Text="BUILD 9.0.0  //  STABLE"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,38,78,0"
                       Foreground="{StaticResource ElectricBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Opacity="0"/>
            <TextBlock x:Name="HudBL" Text="[OK]  NEURAL UPLINK"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="78,0,0,38"
                       Foreground="{StaticResource PulseBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Opacity="0"/>
            <TextBlock x:Name="HudBR" Text="LATENCY  0.4MS"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,78,38"
                       Foreground="{StaticResource ElectricBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Opacity="0"/>

            <!-- L6: CA wireframe monogram (drawn stroke-by-stroke) -->
            <Canvas x:Name="MonogramCanvas"
                    Width="180" Height="140"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,-30,0,0">

                <!-- C glyph (open hex shape) -->
                <Path x:Name="GlyphC"
                      Stroke="{StaticResource ElectricBrush}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M 70,15 L 25,15 L 5,55 L 25,95 L 70,95"/>

                <!-- A glyph (triangle with crossbar) -->
                <Path x:Name="GlyphA"
                      Stroke="{StaticResource ElectricBrush}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M 95,95 L 130,15 L 165,95 M 108,68 L 152,68"/>

                <!-- Liquid fill rectangle (clipped to bottom-up reveal) -->
                <Rectangle x:Name="LiquidFill"
                           Canvas.Left="0" Canvas.Top="0"
                           Width="180" Height="0"
                           Fill="#3300F0FF"
                           Opacity="0"/>
            </Canvas>

            <!-- L7: final wordmark group -->
            <StackPanel x:Name="WordmarkGroup"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,-30,0,0"
                        Opacity="0">
                <TextBlock Text="CORE_AIM_PRO"
                           FontFamily="{StaticResource DisplayFont}"
                           FontSize="48" FontWeight="Bold"
                           Foreground="#FFFFFFFF"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF00F0FF" BlurRadius="20" ShadowDepth="0" Opacity="0.95"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Rectangle x:Name="PlasmaUnderline"
                           Height="2" Width="0"
                           HorizontalAlignment="Center"
                           Fill="{StaticResource PlasmaBrush}"
                           Margin="0,4,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FFB400FF" BlurRadius="10" ShadowDepth="0"/>
                    </Rectangle.Effect>
                </Rectangle>
                <TextBlock x:Name="WordmarkSub"
                           Text=""
                           Foreground="{StaticResource ElectricBrush}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
