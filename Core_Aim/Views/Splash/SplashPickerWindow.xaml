<Window x:Class="Core_Aim.Views.Splash.SplashPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Core_Aim_pro · Select Splash Style"
        Width="900" Height="540"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="20">
        <!-- Outer drop shadow border -->
        <Border CornerRadius="3"
                Background="{StaticResource VoidBrush}"
                BorderBrush="{StaticResource StrokeHardBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#FF00F0FF" BlurRadius="40" ShadowDepth="0" Opacity="0.45"/>
            </Border.Effect>

            <Grid ClipToBounds="True">
                <!-- L1: void background -->
                <Rectangle Fill="{StaticResource VoidBrush}"/>
                <!-- L2: hex grid -->
                <Rectangle Fill="{StaticResource HexGridBrushDense}" Opacity="0.5"/>

                <!-- L3: corner orbs -->
                <Ellipse Width="320" Height="320"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-100,-100,0,0"
                         Fill="{StaticResource ElectricOrbBrush}"
                         Opacity="0.45"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="42"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="280" Height="280"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-100,-100"
                         Fill="{StaticResource PlasmaOrbBrush}"
                         Opacity="0.4"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="42"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- L4: vignette -->
                <Rectangle Fill="{StaticResource VignetteBrush}" IsHitTestVisible="False"/>

                <!-- L5: content -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ═══ TITLE BAR ═══ -->
                    <Grid Grid.Row="0" Background="#80010206"
                          MouseDown="TitleBar_MouseDown">
                        <Rectangle Height="1" VerticalAlignment="Bottom"
                                   Fill="{StaticResource TitleAccentBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource ElectricBrush}" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF00F0FF" BlurRadius="8" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="CORE_AIM_PRO  ·  SPLASH STYLE  ·  SELECT BOOT SEQUENCE"
                                       Foreground="{StaticResource ElectricBrush}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" FontWeight="Bold"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Click="Close_Click"
                                Style="{StaticResource PhantomChromeClose}"
                                HorizontalAlignment="Right"
                                Content="✕"/>
                    </Grid>

                    <!-- ═══ BODY ═══ -->
                    <Grid Grid.Row="1" Margin="32,24,32,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,18">
                            <TextBlock Text="// SELECT BOOT SEQUENCE"
                                       Style="{StaticResource PhantomLabelHi}"/>
                            <TextBlock Text="Choose how Core_Aim_pro wakes up. Preview each one — your pick saves automatically."
                                       Foreground="{StaticResource TextDimBrush}"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="11"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- Three cards -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── CARD A — NEURAL BOOT ── -->
                            <Border x:Name="CardA" Grid.Column="0"
                                    Background="{StaticResource AbyssBrush}"
                                    BorderBrush="{StaticResource StrokeSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Static thumbnail: telemetry log + glitch logo -->
                                    <Grid Grid.Row="0" Margin="0">
                                        <Rectangle Fill="{StaticResource HexGridBrushDense}" Opacity="0.55"/>
                                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                    Margin="14,0,0,14">
                                            <TextBlock Text="&gt; NEURAL CORE ... ONLINE"
                                                       Foreground="{StaticResource ElectricBrush}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="8"/>
                                            <TextBlock Text="&gt; TENSORS ........ READY"
                                                       Foreground="{StaticResource ElectricBrush}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="8"/>
                                            <TextBlock Text="&gt; HID BRIDGE ..... TT2"
                                                       Foreground="{StaticResource ElectricBrush}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="8"/>
                                        </StackPanel>
                                        <TextBlock Text="CORE_AIM_PRO"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="#FFFFFFFF"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-6,0,0">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#FF00F0FF" BlurRadius="14" ShadowDepth="0" Opacity="0.9"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Title + description -->
                                    <StackPanel Grid.Row="1" Margin="14,12,14,8">
                                        <TextBlock Text="A · NEURAL BOOT"
                                                   Foreground="{StaticResource ElectricBrush}"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="Terminal boot log + glitch RGB-split reveal."
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Buttons -->
                                    <Grid Grid.Row="2" Margin="14,0,14,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="PREVIEW"
                                                Style="{StaticResource PhantomButtonGhost}"
                                                Height="30"
                                                Click="PreviewNeural_Click"/>
                                        <Button Grid.Column="2"
                                                Content="SELECT"
                                                Style="{StaticResource PhantomButton}"
                                                Height="30"
                                                Click="SelectNeural_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ── CARD B — REACTOR IGNITION ── -->
                            <Border x:Name="CardB" Grid.Column="2"
                                    Background="{StaticResource AbyssBrush}"
                                    BorderBrush="{StaticResource StrokeSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Static thumbnail: concentric rings -->
                                    <Grid Grid.Row="0">
                                        <Rectangle Fill="{StaticResource HexGridBrushDense}" Opacity="0.45"/>
                                        <Ellipse Width="120" Height="120" Stroke="#FF00F0FF" StrokeThickness="1"
                                                 StrokeDashArray="2 6"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Width="90" Height="90" Stroke="#FFB400FF" StrokeThickness="1"
                                                 StrokeDashArray="6 4"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Width="60" Height="60" Stroke="#FF80E8FF" StrokeThickness="1.2"
                                                 StrokeDashArray="1 9"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Width="6" Height="6" Fill="#FFFFFFFF"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#FF00F0FF" BlurRadius="20" ShadowDepth="0"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Margin="14,12,14,8">
                                        <TextBlock Text="B · REACTOR IGNITION"
                                                   Foreground="{StaticResource ElectricBrush}"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="Spinning rings collapse into a flash + logo."
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2" Margin="14,0,14,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="PREVIEW"
                                                Style="{StaticResource PhantomButtonGhost}"
                                                Height="30"
                                                Click="PreviewReactor_Click"/>
                                        <Button Grid.Column="2"
                                                Content="SELECT"
                                                Style="{StaticResource PhantomButton}"
                                                Height="30"
                                                Click="SelectReactor_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ── CARD C — HOLOGRAPHIC ── -->
                            <Border x:Name="CardC" Grid.Column="4"
                                    Background="{StaticResource AbyssBrush}"
                                    BorderBrush="{StaticResource StrokeSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Static thumbnail: brackets + CA wireframe -->
                                    <Grid Grid.Row="0">
                                        <Rectangle Fill="{StaticResource HexGridBrushDense}" Opacity="0.45"/>
                                        <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.2"
                                              Data="M 0,18 L 0,0 L 18,0"
                                              Margin="10,10,0,0"
                                              HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                        <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.2"
                                              Data="M 0,0 L 18,0 L 18,18"
                                              Margin="0,10,10,0"
                                              HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                        <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.2"
                                              Data="M 0,0 L 0,18 L 18,18"
                                              Margin="10,0,0,10"
                                              HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                        <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.2"
                                              Data="M 0,18 L 18,18 L 18,0"
                                              Margin="0,0,10,10"
                                              HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="2"
                                                  Data="M 50,10 L 18,10 L 4,38 L 18,66 L 50,66"/>
                                            <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="2"
                                                  Margin="6,0,0,0"
                                                  Data="M 0,66 L 24,10 L 48,66 M 9,48 L 39,48"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Margin="14,12,14,8">
                                        <TextBlock Text="C · HOLOGRAPHIC"
                                                   Foreground="{StaticResource ElectricBrush}"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="Wireframe CA monogram + liquid fill assembly."
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2" Margin="14,0,14,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="PREVIEW"
                                                Style="{StaticResource PhantomButtonGhost}"
                                                Height="30"
                                                Click="PreviewHolo_Click"/>
                                        <Button Grid.Column="2"
                                                Content="SELECT"
                                                Style="{StaticResource PhantomButton}"
                                                Height="30"
                                                Click="SelectHolo_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Footer status -->
                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="StatusText"
                                       Grid.Column="0"
                                       Text="// CURRENT: NEURAL BOOT"
                                       Style="{StaticResource PhantomLabelHi}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="CONTINUE"
                                    Style="{StaticResource PhantomButton}"
                                    Height="32"
                                    Padding="22,6"
                                    Click="Continue_Click"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Corner brackets -->
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,18 L 0,0 L 18,0"
                      Margin="4,4,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,0 L 18,0 L 18,18"
                      Margin="0,4,4,0" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,0 L 0,18 L 18,18"
                      Margin="4,0,0,4" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,18 L 18,18 L 18,0"
                      Margin="0,0,4,4" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>
    </Grid>
</Window>
