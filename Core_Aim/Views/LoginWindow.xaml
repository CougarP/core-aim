<Window x:Class="Core_Aim.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Core_Aim.ViewModels"
        xmlns:converters="clr-namespace:Core_Aim.Converters"
        mc:Ignorable="d"
        Title="Core_Aim_pro · Authentication"
        Height="640" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.DataContext>
        <viewmodels:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Enter"
                    Command="{Binding ExecuteAuthCommand}"
                    CommandParameter="{Binding ElementName=PassBox}"/>
    </Window.InputBindings>

    <!-- ══════════════════════════════════════════════════════════════
         ROOT — outer transparent area for shadow + glow margin
         ══════════════════════════════════════════════════════════════ -->
    <Grid Margin="20" RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="0.85" ScaleY="0.85"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         From="0.85" To="1" Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction>
                                <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         From="0.85" To="1" Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction>
                                <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.3"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <!-- ─── Outer drop shadow border ─── -->
        <Border CornerRadius="3"
                Background="{StaticResource VoidBrush}"
                BorderBrush="{StaticResource StrokeHardBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#FF00F0FF" BlurRadius="40" ShadowDepth="0" Opacity="0.45"/>
            </Border.Effect>

            <!-- ─── LAYER STACK ─── -->
            <Grid ClipToBounds="True">

                <!-- L1: void background -->
                <Rectangle Fill="{StaticResource VoidBrush}"/>

                <!-- L2: hex grid (dense variant for popup) -->
                <Rectangle Fill="{StaticResource HexGridBrushDense}" Opacity="0.55"/>

                <!-- L3: corner energy orbs -->
                <Ellipse Width="280" Height="280"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-90,-90,0,0"
                         Fill="{StaticResource ElectricOrbBrush}"
                         Opacity="0.5"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="40"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="240" Height="240"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-80,-80"
                         Fill="{StaticResource PlasmaOrbBrush}"
                         Opacity="0.45"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="40"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- L4: vignette -->
                <Rectangle Fill="{StaticResource VignetteBrush}" IsHitTestVisible="False"/>

                <!-- L5: scanline overlay -->
                <Rectangle Opacity="0.05" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute" Stretch="None">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#FF00F0FF">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,4,1"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- L6: content -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ═══ TITLE BAR ═══ -->
                    <Grid Grid.Row="0" Background="#80010308"
                          MouseDown="TitleBar_MouseDown">

                        <!-- Bottom electric line -->
                        <Rectangle Height="1" VerticalAlignment="Bottom"
                                   Fill="{StaticResource TitleAccentBrush}"/>

                        <!-- Title -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource ElectricBrush}" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF00F0FF" BlurRadius="8" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="CORE_AIM_PRO  ·  AUTH"
                                       Foreground="{StaticResource ElectricBrush}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" FontWeight="Bold"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Close -->
                        <Button Command="{Binding CloseCommand}"
                                Style="{StaticResource PhantomChromeClose}"
                                HorizontalAlignment="Right"
                                Content="✕"/>
                    </Grid>

                    <!-- ═══ CONTENT ═══ -->
                    <StackPanel Grid.Row="1" Margin="36,18,36,24" VerticalAlignment="Top">

                        <!-- ── HERO BLOCK ── -->
                        <Border Width="64" Height="64" CornerRadius="2"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,18"
                                Background="{StaticResource AbyssBrush}"
                                BorderBrush="{StaticResource ElectricBrush}"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF00F0FF" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                            </Border.Effect>
                            <TextBlock Text="CA"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="Bold"
                                       FontSize="26"
                                       Foreground="{StaticResource ElectricBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="CORE_AIM_PRO"
                                   Style="{StaticResource PhantomDisplaySm}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="ASSISTIVE TARGETING SYSTEM"
                                   Style="{StaticResource PhantomLabel}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,22"/>

                        <!-- ── USERNAME ── -->
                        <TextBlock Text="// USERNAME" Style="{StaticResource PhantomLabelHi}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PhantomTextBox}"
                                 Margin="0,0,0,14"/>

                        <!-- ── PASSWORD ── -->
                        <TextBlock Text="// PASSWORD" Style="{StaticResource PhantomLabelHi}" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="PassBox"
                                     Style="{StaticResource PhantomPasswordBox}"
                                     Margin="0,0,0,14"/>

                        <!-- ── LICENSE KEY (register only) ── -->
                        <StackPanel Visibility="{Binding LicenseVisibility}">
                            <TextBlock Text="// LICENSE KEY" Style="{StaticResource PhantomLabelHi}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PhantomTextBox}"
                                     Margin="0,0,0,14"/>
                        </StackPanel>

                        <!-- ── AUTO LOGIN ── -->
                        <CheckBox IsChecked="{Binding AutoLogin, Mode=TwoWay}"
                                  Style="{StaticResource PhantomCheckBox}"
                                  Content="AUTO-LOGIN ON LAUNCH"
                                  Margin="0,2,0,16"/>

                        <!-- ── ACTION BUTTON ── -->
                        <Button Content="{Binding ActionButtonText}"
                                Command="{Binding ExecuteAuthCommand}"
                                CommandParameter="{Binding ElementName=PassBox}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource PhantomButton}"
                                Height="42" Margin="0,0,0,12"/>

                        <!-- ── STATUS ── -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SolarBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <!-- ── MODE TOGGLE + SPLASH PICKER ── -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="{Binding SwitchModeText}"
                                    Command="{Binding ToggleModeCommand}"
                                    Style="{StaticResource PhantomButtonGhost}"
                                    Height="30"
                                    Padding="14,4"/>
                            <Button Content="// SPLASH"
                                    Click="OpenSplashPicker_Click"
                                    Style="{StaticResource PhantomButtonGhost}"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Padding="14,4"
                                    ToolTip="Choose Phantom boot sequence"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <!-- L7: corner brackets (decorative) -->
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,18 L 0,0 L 18,0"
                      Margin="4,4,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,0 L 18,0 L 18,18"
                      Margin="0,4,4,0" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,0 L 0,18 L 18,18"
                      Margin="4,0,0,4" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                <Path Stroke="{StaticResource ElectricBrush}" StrokeThickness="1.5"
                      Data="M 0,18 L 18,18 L 18,0"
                      Margin="0,0,4,4" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

            </Grid>
        </Border>
    </Grid>
</Window>
