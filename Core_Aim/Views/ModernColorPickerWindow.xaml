<Window x:Class="Core_Aim.Views.ModernColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Select Color" Height="500" Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#181A20">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0" Stretch="Uniform" Margin="0,0,0,20">
            <xctk:ColorCanvas x:Name="MyColorCanvas" 
                              Background="Transparent"
                              Foreground="White"
                              UsingAlphaChannel="False" 
                              BorderThickness="0"/>
        </Viewbox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" IsCancel="True" 
                    Background="#333" Foreground="White" Padding="20,8" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Confirm Color" Click="OkButton_Click" 
                    Background="#6366F1" Foreground="White" FontWeight="Bold" Padding="20,8" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>