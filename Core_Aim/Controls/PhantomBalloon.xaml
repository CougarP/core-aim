<Window x:Class="Core_Aim.Controls.PhantomBalloon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Title="PhantomBalloon">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM BALLOON — spec §7
         WINDOW FLUTUANTE • DRAG • PIN • CORNER BRACKETS • ENTRADA
         ═══════════════════════════════════════════════════════════════ -->

    <Window.Resources>
        <!-- PIN toggle -->
        <Style x:Key="PinToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#FF506070"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FF1E2E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5500F0FF"/>
                                <Setter Property="Foreground" Value="#FF8AAABB"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF00F0FF"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1A00F0FF"/>
                                <Setter Property="Foreground" Value="#FF00F0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CLOSE button -->
        <Style x:Key="BalloonClose" TargetType="Button">
            <Setter Property="Foreground" Value="#FF506070"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FF1E2E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <TextBlock Text="✕"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFF3000"/>
                                <Setter TargetName="Bd" Property="Background" Value="#22FF3000"/>
                                <Setter Property="Foreground" Value="#FFFF3000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="Root"
            Background="#F203070F"
            BorderBrush="#FF1E2E42"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="8"
                              BlurRadius="18"
                              Color="Black"
                              Opacity="0.7"/>
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform x:Name="EntryScale" ScaleY="1"/>
        </Border.RenderTransform>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top line gradient (animated breathing) -->
            <Rectangle Grid.Row="0" x:Name="TopLine">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#FF00F0FF" Offset="0.4"/>
                        <GradientStop Color="#FFB400FF" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.5" To="1.0"
                                                 Duration="0:0:3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <!-- Header (drag) -->
            <Border Grid.Row="1"
                    Background="#66000000"
                    BorderBrush="#FF162030"
                    BorderThickness="0,0,0,1"
                    Padding="8,8"
                    MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="⠿"
                               Foreground="#FF304050"
                               FontSize="11"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Cursor="SizeAll"/>

                    <TextBlock x:Name="TitleText"
                               Grid.Column="1"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="#FF8AAABB"
                               VerticalAlignment="Center"/>

                    <ToggleButton x:Name="PinBtn"
                                  Grid.Column="2"
                                  Content="◈ FIXAR"
                                  Style="{StaticResource PinToggle}"
                                  Checked="Pin_Checked"
                                  Unchecked="Pin_Unchecked"
                                  Margin="6,0"/>

                    <Button Grid.Column="3"
                            Click="Close_Click"
                            Style="{StaticResource BalloonClose}"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ContentPresenter Grid.Row="2"
                              x:Name="BalloonContent"
                              Margin="13"/>
        </Grid>
    </Border>
</Window>
