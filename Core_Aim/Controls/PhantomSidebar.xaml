<UserControl x:Class="Core_Aim.Controls.PhantomSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM SIDEBAR — spec §01 + balloons mockup
         38px fixed width • vertical stack of icon items
         active item = bg Electric 9% + border Electric 20% + 2px left rail glow
         Each item binds IsChecked → IsXXVisible (Mode=OneWay) and
         Command → ToggleTabCommand with the tab code as parameter.
         ═══════════════════════════════════════════════════════════════ -->

    <UserControl.Resources>
        <Style x:Key="SidebarItem" TargetType="ToggleButton">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FF506070"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Rectangle x:Name="Rail"
                                       Width="2"
                                       HorizontalAlignment="Left"
                                       Fill="#FF00F0FF"
                                       Visibility="Collapsed">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#FF00F0FF" ShadowDepth="0"
                                                      BlurRadius="8" Opacity="0.9"/>
                                </Rectangle.Effect>
                            </Rectangle>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="2,3,2,3">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <!-- Pulsing indicator dot — visible only when active (IsChecked=true) -->
                            <Ellipse x:Name="PulseDot"
                                     Width="5" Height="5"
                                     Fill="#FF00F0FF"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Top"
                                     Margin="0,5,5,0"
                                     Visibility="Collapsed">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF00F0FF" ShadowDepth="0"
                                                      BlurRadius="6" Opacity="1"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0800F0FF"/>
                                <Setter Property="Foreground" Value="#FF8AAABB"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1700F0FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3300F0FF"/>
                                <Setter TargetName="Rail" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PulseDot" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#FF00F0FF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="PulseSb">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PulseDot"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.15"
                                                             Duration="0:0:0.7"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="PulseSb"/>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#FF03070F"
            BorderBrush="#FF162030"
            BorderThickness="0,0,1,0">
        <DockPanel LastChildFill="False">
            <!-- USR docked FIRST so it always gets space at bottom -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" Margin="0,0,0,8">
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsUSRVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="USR"
                              ToolTip="User">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="◈" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="USR" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,8,0,0">
                <!-- 1. Hardware -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsHWVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="HW"
                              ToolTip="Hardware">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="⌬" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="HW" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 2. Capture -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsCAPVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="CAP"
                              ToolTip="Capture">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="▣" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="CAP" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 3. Vision -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsVISVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="VIS"
                              ToolTip="Vision">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="◉" FontSize="19" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="VIS" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 4. Tracking -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsTRKVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="TRK"
                              ToolTip="Tracking">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="➤" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="TRK" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 5. Detection -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsDETVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="DET"
                              ToolTip="Detection">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="◎" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="DET" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 6. Overlay -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsOVLVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="OVL"
                              ToolTip="Overlay">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="▦" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="OVL" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 7. Monitor -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsMONVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="MON"
                              ToolTip="Monitor">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="▤" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="MON" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 8. Trigger / Macros -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsTRGVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="TRG"
                              ToolTip="Trigger / Macros">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="▶" FontSize="17" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="TRG" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 9. Training / Label -->
                <ToggleButton Style="{StaticResource SidebarItem}"
                              IsChecked="{Binding IsTRNVisible, Mode=OneWay}"
                              Command="{Binding ToggleTabCommand}" CommandParameter="TRN"
                              ToolTip="Training Studio / Label Maker">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="⌖" FontSize="19" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="TRN" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
