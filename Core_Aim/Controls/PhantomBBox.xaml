<UserControl x:Class="Core_Aim.Controls.PhantomBBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM BBOX — spec §9
         Reticule corners (TL/TR/BL/BR 10x10 thickness 2)
         + label diagonal clip (top-left, classId-driven color).
         ═══════════════════════════════════════════════════════════════ -->

    <Grid>
        <!-- Background semi-transparent -->
        <Rectangle x:Name="BgRect"
                   Fill="#0800F0FF"
                   Stroke="#A600F0FF"
                   StrokeThickness="1"/>

        <!-- Corner TL -->
        <Border Width="10" Height="10"
                BorderThickness="2,2,0,0"
                BorderBrush="#FF00F0FF"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="-1,-1,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#FF00F0FF" ShadowDepth="0" BlurRadius="6"/>
            </Border.Effect>
        </Border>

        <!-- Corner TR -->
        <Border Width="10" Height="10"
                BorderThickness="0,2,2,0"
                BorderBrush="#FF00F0FF"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-1,-1,0"/>

        <!-- Corner BL -->
        <Border Width="10" Height="10"
                BorderThickness="2,0,0,2"
                BorderBrush="#FF00F0FF"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="-1,0,0,-1"/>

        <!-- Corner BR -->
        <Border Width="10" Height="10"
                BorderThickness="0,0,2,2"
                BorderBrush="#FF00F0FF"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,-1,-1"/>

        <!-- Label with diagonal clip -->
        <Border x:Name="LabelBorder"
                Background="#FF00F0FF"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="-1,-18,0,0"
                Padding="5,2,10,2"
                SizeChanged="LabelBorder_SizeChanged">
            <Border.Clip>
                <PathGeometry x:Name="LabelClip"/>
            </Border.Clip>
            <TextBlock x:Name="LabelText"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="9"
                       FontWeight="Bold"
                       Foreground="Black"/>
        </Border>
    </Grid>
</UserControl>
