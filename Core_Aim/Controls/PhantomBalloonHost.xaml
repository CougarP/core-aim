<UserControl x:Class="Core_Aim.Controls.PhantomBalloonHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Self"
             VerticalAlignment="Top"
             Margin="0,0,12,0">

    <!-- ═══════════════════════════════════════════════════════════════
         PHANTOM BALLOON HOST — spec phantom_balloons.txt §404-422
         Embedded version (não-Window). Mantém:
         - Top line animada (gradient electric→plasma + breathing)
         - Header com título + botão close
         - Corner brackets (TL Electric, BR Plasma)
         - Entrance animation 140ms (fade + scaleY)
         ═══════════════════════════════════════════════════════════════ -->

    <UserControl.Resources>
        <Style x:Key="BalloonCloseBtn" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FF1E2E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FF506070"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="✕"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FF3000"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFF3000"/>
                                <Setter Property="Foreground" Value="#FFFF3000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="Root"
            Background="#F203070F"
            BorderBrush="#FF1E2E42"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0">
        <!-- spec phantom_docs.txt §7 / phantom_balloons.txt §404:
             DropShadowEffect ShadowDepth=20 BlurRadius=40 Color=Black Opacity=0.85 -->
        <Border.Effect>
            <DropShadowEffect ShadowDepth="20" BlurRadius="40" Color="Black" Opacity="0.85"/>
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform x:Name="EntryScale" ScaleY="1"/>
        </Border.RenderTransform>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top line animada (gradient + breathing) -->
            <Rectangle Grid.Row="0" x:Name="TopLine">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#FF00F0FF" Offset="0.4"/>
                        <GradientStop Color="#FFB400FF" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.5" To="1.0"
                                                 Duration="0:0:3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <!-- Header (título + close) — spec padding 8,8 -->
            <Border Grid.Row="1"
                    Background="#66000000"
                    BorderBrush="#FF162030"
                    BorderThickness="0,0,0,1"
                    Padding="8,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- spec phantom_docs.txt §7 / phantom_balloons.txt §404:
                         titulo = Share Tech Mono, FontSize 8, Foreground #304050 -->
                    <TextBlock x:Name="TitleText"
                               Text="{Binding Title, ElementName=Self}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="8"
                               FontWeight="Bold"
                               Foreground="#FF304050"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource BalloonCloseBtn}"
                            Command="{Binding CloseTabCommand}"
                            CommandParameter="{Binding TabCode, ElementName=Self}"/>
                </Grid>
            </Border>

            <!-- Conteúdo -->
            <ContentPresenter Grid.Row="2" Content="{Binding Content, ElementName=Self}" Margin="0"/>

            <!-- Corner brackets — TL Electric, BR Plasma -->
            <Border Grid.RowSpan="3"
                    Width="12" Height="12"
                    BorderBrush="#FF00F0FF"
                    BorderThickness="1,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"/>
            <Border Grid.RowSpan="3"
                    Width="12" Height="12"
                    BorderBrush="#FFB400FF"
                    BorderThickness="0,0,1,1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    IsHitTestVisible="False"/>
        </Grid>
    </Border>
</UserControl>
